---
interface Props {
  title: string;
  description: string;
  /** Additional Google Fonts families string (after `family=`) */
  fonts?: string;
  /** Path or absolute URL to the OG image. Defaults to /og-image.png. */
  image?: string;
}

const {
  title,
  description,
  fonts = 'Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Instrument+Serif:ital@1&family=JetBrains+Mono:wght@400;500',
  image = '/og-image.png',
} = Astro.props;

const fontsHref = `https://fonts.googleapis.com/css2?family=${fonts}&display=swap`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://ilo-lang.ai';
const ogImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Daniel John Morris" />
<meta name="theme-color" content="#f59e0b" />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Open Graph -->
<meta property="og:site_name" content="ilo" />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:site" content="@danielmorris" />
<meta name="twitter:creator" content="@danielmorris" />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={fontsHref} rel="stylesheet" />
<script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="39ac022b-8282-43ec-8e1a-7fd9dc222f39"></script>
