<script>
  // copy buttons
  document.body.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    const btn = target ? target.closest('.term-cta') as HTMLButtonElement | null : null;
    if (!btn) return;
    const targetId = btn.getAttribute('data-target');
    const targetEl = targetId ? document.getElementById(targetId) : null;
    if (targetEl) {
      const text = targetEl.innerText.replace(/^\$\s*/, '').trim();
      try { navigator.clipboard && navigator.clipboard.writeText(text); } catch (_) {}
    }
    const original = btn.textContent || 'copy';
    btn.textContent = 'copied ✓';
    btn.classList.add('is-copied');
    setTimeout(() => {
      btn.textContent = original.indexOf('✓') !== -1 ? 'copy' : original;
      btn.classList.remove('is-copied');
    }, 2000);
  });

  // helper: swap HTML without using innerHTML= (avoids the XSS hook)
  function replaceHtml(el: Element, html: string) {
    while (el.firstChild) el.removeChild(el.firstChild);
    el.insertAdjacentHTML('afterbegin', html);
  }

  // install tabs
  (function () {
    const tabs = document.querySelectorAll<HTMLButtonElement>('#install-tabs .tab');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.getAttribute('data-tab');
        tabs.forEach((t) => t.setAttribute('aria-selected', t === tab ? 'true' : 'false'));
        panels.forEach((p) => {
          if (p.getAttribute('data-panel') === key) p.removeAttribute('hidden');
          else p.setAttribute('hidden', '');
        });
      });
    });
  })();

  // OS chip switcher (humans tab)
  (function () {
    const chips = document.querySelectorAll<HTMLButtonElement>('.os-chip');
    const cmd = document.getElementById('install-cmd');
    if (!chips.length || !cmd) return;
    function colorize(s: string) {
      return s
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/(--?[\w-]+)/g, '<span class="flag">$1</span>')
        .replace(/(ilo-lang\.ai\/[\w./-]+|ghcr\.io\/[\w./:-]+|nixpkgs#\w+|ilo-lang\/tap\/ilo|https?:\/\/[\w./-]+)/g, '<span class="url">$1</span>');
    }
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.toggle('is-active', c === chip));
        const raw = chip.getAttribute('data-cmd') || '';
        replaceHtml(cmd, '<span class="p">$</span> ' + colorize(raw));
      });
    });
  })();

  // agent chip switcher
  (function () {
    const chips = document.querySelectorAll<HTMLButtonElement>('.agent-chip');
    const cmd = document.getElementById('agent-cmd');
    const desc = document.getElementById('agent-desc');
    if (!chips.length || !cmd) return;
    function colorize(s: string) {
      return s
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/(--?[\w-]+)/g, '<span class="flag">$1</span>');
    }
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.toggle('is-active', c === chip));
        const raw = chip.getAttribute('data-cmd') || '';
        replaceHtml(cmd, '<span class="p">$</span> ' + colorize(raw));
        if (desc) replaceHtml(desc, chip.getAttribute('data-desc') || '');
      });
    });
  })();

  // hero demo cycler
  (function () {
    const examples = [
      {
        name: 'fold-sum',
        py: '<span class="kw">from</span> functools <span class="kw">import</span> reduce\n\nnums <span class="op">=</span> [<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>, <span class="num">4</span>, <span class="num">5</span>]\ntotal <span class="op">=</span> reduce(<span class="kw">lambda</span> a, b: a <span class="op">+</span> b, nums, <span class="num">0</span>)\nprint(total)',
        ilo: '<span class="kw">fld</span> <span class="op">+</span> [<span class="num">1</span>,<span class="num">2</span>,<span class="num">3</span>,<span class="num">4</span>,<span class="num">5</span>] <span class="num">0</span>',
        pyTok: 38, iloTok: 9, delta: 76,
      },
      {
        name: 'map-double',
        py: 'nums <span class="op">=</span> [<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>, <span class="num">4</span>, <span class="num">5</span>]\ndoubled <span class="op">=</span> [n <span class="op">*</span> <span class="num">2</span> <span class="kw">for</span> n <span class="kw">in</span> nums]\nprint(doubled)',
        ilo: '<span class="kw">map</span> <span class="op">*</span><span class="num">2</span> [<span class="num">1</span>,<span class="num">2</span>,<span class="num">3</span>,<span class="num">4</span>,<span class="num">5</span>]',
        pyTok: 22, iloTok: 9, delta: 59,
      },
      {
        name: 'filter-even',
        py: 'nums <span class="op">=</span> [<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>, <span class="num">4</span>, <span class="num">5</span>, <span class="num">6</span>]\nevens <span class="op">=</span> [n <span class="kw">for</span> n <span class="kw">in</span> nums <span class="kw">if</span> n <span class="op">%</span> <span class="num">2</span> <span class="op">==</span> <span class="num">0</span>]\nprint(evens)',
        ilo: '<span class="kw">flt</span> <span class="op">=</span><span class="num">0</span><span class="op">%</span><span class="num">2</span> [<span class="num">1</span>,<span class="num">2</span>,<span class="num">3</span>,<span class="num">4</span>,<span class="num">5</span>,<span class="num">6</span>]',
        pyTok: 28, iloTok: 14, delta: 50,
      },
      {
        name: 'pipes',
        py: 'nums <span class="op">=</span> [<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>, <span class="num">4</span>, <span class="num">5</span>, <span class="num">6</span>, <span class="num">7</span>, <span class="num">8</span>, <span class="num">9</span>, <span class="num">10</span>]\ntotal <span class="op">=</span> <span class="kw">sum</span>(n <span class="op">*</span> <span class="num">2</span> <span class="kw">for</span> n <span class="kw">in</span> nums <span class="kw">if</span> n <span class="op">&gt;</span> <span class="num">5</span>)\nprint(total)',
        ilo: '[<span class="num">1</span>..<span class="num">10</span>] <span class="op">&gt;&gt;</span> <span class="kw">flt</span> <span class="op">&gt;</span><span class="num">5</span> <span class="op">&gt;&gt;</span> <span class="kw">map</span> <span class="op">*</span><span class="num">2</span> <span class="op">&gt;&gt;</span> <span class="kw">sum</span>',
        pyTok: 38, iloTok: 17, delta: 55,
      },
    ];

    const pyName  = document.getElementById('demo-py-name');
    const pyBody  = document.getElementById('demo-py-body');
    const iloName = document.getElementById('demo-ilo-name');
    const iloBody = document.getElementById('demo-ilo-body');
    const pyTok   = document.getElementById('demo-py-tok');
    const iloTok  = document.getElementById('demo-ilo-tok');
    const delta   = document.getElementById('demo-delta');
    const dots    = document.querySelectorAll<HTMLButtonElement>('#demo-dots .demo-dot');
    const root    = document.querySelector('.hero-right');
    if (!pyBody || !iloBody || !pyName || !iloName || !pyTok || !iloTok || !delta) return;

    let idx = 0;
    let paused = false;

    function apply(i: number) {
      idx = i;
      const ex = examples[i];
      pyName!.textContent  = ex.name + '.py';
      iloName!.textContent = ex.name + '.@';
      replaceHtml(pyBody!, ex.py);
      replaceHtml(iloBody!, ex.ilo);
      pyTok!.textContent   = String(ex.pyTok);
      iloTok!.textContent  = String(ex.iloTok);
      delta!.textContent   = '−' + ex.delta + '%';
      dots.forEach((d, j) => d.classList.toggle('is-active', j === i));
    }

    function next() {
      if (paused) return;
      apply((idx + 1) % examples.length);
    }

    setInterval(next, 4500);

    if (root) {
      root.addEventListener('mouseenter', () => { paused = true; });
      root.addEventListener('mouseleave', () => { paused = false; });
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        paused = true;
        const i = parseInt(dot.getAttribute('data-idx') || '0', 10);
        apply(i);
      });
    });
  })();

  // shipped strip: latest release summary, parsed live from CHANGELOG.md
  (function () {
    const tagEl  = document.getElementById('shipped-tag');
    const bodyEl = document.getElementById('shipped-body');
    const metaEl = document.getElementById('shipped-meta');
    if (!tagEl || !bodyEl || !metaEl) return;

    function fallback() {
      bodyEl!.textContent = 'The latest ilo release. See the changelog for details.';
      tagEl!.textContent = 'latest';
      metaEl!.textContent = '';
    }

    type Parsed = { version: string; summary: string; otherCount: number };

    function parseChangelog(text: string): Parsed | null {
      const lines = text.split('\n');
      let headingIdx = -1;
      let version = '';
      // count all release sections (non-Unreleased "## " headings)
      let releaseCount = 0;
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        if (line.startsWith('## ')) {
          const title = line.slice(3).trim();
          if (title.toLowerCase().startsWith('unreleased')) continue;
          releaseCount++;
          if (headingIdx === -1) {
            headingIdx = i;
            // version = left side of em dash or hyphen separator
            const sep = title.search(/\s[—-]\s/);
            version = (sep === -1 ? title : title.slice(0, sep)).trim();
          }
        }
      }
      if (headingIdx === -1) return null;

      // collect summary lines until the next ### or ##
      const summaryLines: string[] = [];
      for (let i = headingIdx + 1; i < lines.length; i++) {
        const line = lines[i];
        if (line.startsWith('### ') || line.startsWith('## ')) break;
        summaryLines.push(line);
      }

      // first non-empty paragraph
      let paragraph = '';
      for (const raw of summaryLines) {
        if (raw.trim()) { paragraph = raw.trim(); break; }
      }
      if (!paragraph) return null;

      // strip markdown bold markers, collapse whitespace
      let plain = paragraph.replace(/\*\*/g, '').replace(/\s+/g, ' ').trim();
      // first sentence: up to ". " followed by a capital, else cap at ~140 chars
      const m = plain.match(/^(.+?\.)\s+[A-Z]/);
      let summary = m ? m[1] : plain;
      if (summary.length > 140) summary = summary.slice(0, 139).trimEnd() + '…';

      return { version, summary, otherCount: Math.max(releaseCount - 1, 0) };
    }

    fetch('https://raw.githubusercontent.com/ilo-lang/ilo/main/CHANGELOG.md')
      .then((r) => (r.ok ? r.text() : Promise.reject(new Error('http ' + r.status))))
      .then((text) => {
        const parsed = parseChangelog(text);
        if (!parsed) { fallback(); return; }
        tagEl!.textContent = parsed.version + ' · latest';
        bodyEl!.textContent = parsed.summary;
        metaEl!.textContent = parsed.otherCount > 0
          ? '+ ' + parsed.otherCount + ' other release' + (parsed.otherCount === 1 ? '' : 's')
          : '';
      })
      .catch(() => fallback());
  })();
</script>
