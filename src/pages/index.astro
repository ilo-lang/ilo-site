// ===== SYNTAX HIGHLIGHTING =====

function escHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// ilo tokenizer / highlighter
const ILO_KW = new Set(['wh','ret','brk','cnt','main','if','else']);
const ILO_BUILTIN = new Set(['map','flt','fld','len','upr','lwr','str','int','mod','spl','cat','at','prnt','hd','tl','srt','rev','rng','fmt','flt','fld','hd','tl','lst','frq','flat','grp','has','ord','sum','min','max','avg','abs','ceil','flr','rnd','log','exp','sqt','sin','cos','tan','zip','unz','rpl','trm','prfx','sfx','sub','idx','inn','cnt','uni','srt','rsrt','dbl','inc','range','push','pop']);

function highlightIlo(src: string): string {
  // Tokenize line by line
  return src.split('\n').map(line => {
    let out = '';
    let i = 0;
    while (i < line.length) {
      const ch = line[i];
      // string literal
      if (ch === '"') {
        let j = i + 1;
        while (j < line.length && !(line[j] === '"' && line[j-1] !== '\\')) j++;
        out += `<span class="syn-s">${escHtml(line.slice(i, j + 1))}</span>`;
        i = j + 1;
        continue;
      }
      // comment
      if (ch === '-' && line[i+1] === '-') {
        out += `<span class="syn-cm">${escHtml(line.slice(i))}</span>`;
        break;
      }
      // number
      if (/[0-9]/.test(ch) || (ch === '-' && /[0-9]/.test(line[i+1] || ''))) {
        let j = i + 1;
        while (j < line.length && /[0-9.]/.test(line[j])) j++;
        out += `<span class="syn-p">${escHtml(line.slice(i, j))}</span>`;
        i = j;
        continue;
      }
      // operators / sigils
      if (/[+\-*\/=<>!|&^%@?~]/.test(ch) || ch === ';' || (ch === '>' && line[i+1] === '>')) {
        let j = i + 1;
        // multi-char ops: >>, >=, <=, !=, >>, >>
        if ((ch === '>' && line[i+1] === '>') || (ch === '>' && line[i+1] === '=') ||
            (ch === '<' && line[i+1] === '=') || (ch === '!' && line[i+1] === '=') ||
            (ch === '+' && line[i+1] === '+') || (ch === '-' && line[i+1] === '>')) {
          j = i + 2;
        }
        const op = line.slice(i, j);
        if (op === ';') {
          out += escHtml(op);
        } else if (op === '>') {
          // could be return type sigil or op — highlight as op
          out += `<span class="syn-op">${escHtml(op)}</span>`;
        } else {
          out += `<span class="syn-op">${escHtml(op)}</span>`;
        }
        i = j;
        continue;
      }
      // identifier or keyword
      if (/[a-zA-Z_\-]/.test(ch)) {
        let j = i + 1;
        while (j < line.length && /[a-zA-Z0-9_\-]/.test(line[j])) j++;
        const word = line.slice(i, j);
        if (ILO_KW.has(word)) {
          out += `<span class="syn-kw">${escHtml(word)}</span>`;
        } else if (ILO_BUILTIN.has(word)) {
          out += `<span class="syn-fn">${escHtml(word)}</span>`;
        } else if (/^[a-z]/.test(word) && j < line.length && line[j] === ' ') {
          // first word on expression that looks like a fn call
          out += `<span class="syn-fn">${escHtml(word)}</span>`;
        } else if (/:[ntbLM]/.test(line.slice(j, j+2))) {
          // param name followed by type sigil
          out += `<span class="syn-p">${escHtml(word)}</span>`;
        } else {
          out += `<span class="syn-p">${escHtml(word)}</span>`;
        }
        i = j;
        continue;
      }
      // type sigil after colon
      if (ch === ':') {
        let j = i + 1;
        const next = line[j];
        if (next && /[ntbLMR]/.test(next)) {
          // :n :t :b :L :M etc
          let k = j + 1;
          // collect e.g. L n, L t
          if (line[k] === ' ' && /[ntbLMR]/.test(line[k+1] || '')) k += 2;
          out += `<span class="syn-t">${escHtml(line.slice(i, k))}</span>`;
          i = k;
        } else {
          out += escHtml(ch);
          i++;
        }
        continue;
      }
      out += escHtml(ch);
      i++;
    }
    return out;
  }).join('\n');
}

// Python tokenizer / highlighter
const PY_KW = new Set(['def','if','elif','else','for','while','in','return','import','from','print','not','and','or','True','False','None','lambda','class','try','except','with','as','pass','break','continue','yield','del','raise','assert','global','nonlocal','is']);

function highlightPy(src: string): string {
  return src.split('\n').map(line => {
    let out = '';
    let i = 0;
    while (i < line.length) {
      const ch = line[i];
      // comment
      if (ch === '#') {
        out += `<span class="syn-cm">${escHtml(line.slice(i))}</span>`;
        break;
      }
      // string (single or double, simple)
      if (ch === '"' || ch === "'") {
        const q = ch;
        // check triple
        const triple = line[i+1] === q && line[i+2] === q;
        if (triple) {
          let j = i + 3;
          while (j < line.length - 2 && !(line[j]===q && line[j+1]===q && line[j+2]===q)) j++;
          out += `<span class="syn-s">${escHtml(line.slice(i, j + 3))}</span>`;
          i = j + 3;
        } else {
          let j = i + 1;
          while (j < line.length && line[j] !== q) { if (line[j] === '\\') j++; j++; }
          out += `<span class="syn-s">${escHtml(line.slice(i, j + 1))}</span>`;
          i = j + 1;
        }
        continue;
      }
      // number
      if (/[0-9]/.test(ch)) {
        let j = i + 1;
        while (j < line.length && /[0-9._xXoObBa-fA-F]/.test(line[j])) j++;
        out += `<span class="syn-p">${escHtml(line.slice(i, j))}</span>`;
        i = j;
        continue;
      }
      // identifier or keyword
      if (/[a-zA-Z_]/.test(ch)) {
        let j = i + 1;
        while (j < line.length && /[a-zA-Z0-9_]/.test(line[j])) j++;
        const word = line.slice(i, j);
        if (PY_KW.has(word)) {
          out += `<span class="syn-kw">${escHtml(word)}</span>`;
        } else if (j < line.length && line[j] === '(') {
          out += `<span class="syn-fn">${escHtml(word)}</span>`;
        } else {
          out += `<span class="syn-p">${escHtml(word)}</span>`;
        }
        i = j;
        continue;
      }
      // operators
      if (/[+\-*\/=<>!%&|^~@]/.test(ch)) {
        let j = i + 1;
        if (j < line.length && /[=+\-*\/]/.test(line[j])) j++;
        out += `<span class="syn-op">${escHtml(line.slice(i, j))}</span>`;
        i = j;
        continue;
      }
      out += escHtml(ch);
      i++;
    }
    return out;
  }).join('\n');
}

const pyEl = document.getElementById('demo-python') as HTMLTextAreaElement;
const pyHighlight = document.querySelector('#py-highlight code') as HTMLElement;
const iloEl = document.getElementById('demo-ilo') as HTMLPreElement;
const iloCode = document.getElementById('ilo-code') as HTMLElement;
const pyTokensEl = document.getElementById('py-tokens')!;
const pyCharsEl = document.getElementById('py-chars')!;
const iloTokensEl = document.getElementById('ilo-tokens')!;
const iloCharsEl = document.getElementById('ilo-chars')!;
const diffEl = document.getElementById('sia-diff')!;
const outputDiv = document.getElementById('demo-output')!;
const outputText = document.getElementById('demo-output-text')!;
const errorDiv = document.getElementById('sia-error')!;
const convertingOverlay = document.getElementById('sia-converting')!;
const toggleBtn = document.getElementById('sia-toggle')!;
const toggleLabel = document.getElementById('sia-toggle-label')!;

// Track raw ilo text for stats
let iloRawText = '';

function getIloText(): string { return iloRawText; }

function updateStats() {
  const py = pyEl.value;
  const ilo = getIloText();
  const pyTok = countTokens(py);
  const iloTok = countTokens(ilo);
  const pyChar = py.length;
  const iloChar = ilo.length;

  animateCounter(pyTokensEl, prevPyTok, pyTok);
  animateCounter(pyCharsEl, prevPyChar, pyChar);
  animateCounter(iloTokensEl, prevIloTok, iloTok);
  animateCounter(iloCharsEl, prevIloChar, iloChar);

  prevPyTok = pyTok;
  prevPyChar = pyChar;
  prevIloTok = iloTok;
  prevIloChar = iloChar;

  if (pyTok > 0 && iloTok > 0) {
    const pct = Math.round((1 - iloTok / pyTok) * 100);
    diffEl.textContent = pct === 0
      ? `0% tokens`
      : `${pct > 0 ? '−' : '+'}${Math.abs(pct)}% tokens`;
    diffEl.classList.remove('bounce');
    void diffEl.offsetWidth; // reflow
    diffEl.classList.add('bounce');
  } else {
    diffEl.textContent = '';
  }
}

function setIloText(text: string, animate = true) {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!animate || reduced) {
    iloRawText = text;
    iloCode.innerHTML = highlightIlo(text);
    updateStats();
    return;
  }
  iloEl.classList.add('is-fading');
  setTimeout(() => {
    iloRawText = text;
    iloCode.innerHTML = highlightIlo(text);
    iloEl.classList.remove('is-fading');
    updateStats();
  }, 150);
}

function loadPreset(idx: number, skipAutoCycle = false) {
  if (!skipAutoCycle) resetAutoCycle();
  activePreset = idx;
  isApiResult = false;
  const p = PRESETS[idx];

  pyEl.value = p.python;
  pyHighlight.innerHTML = highlightPy(p.python);
  document.querySelectorAll('.sia-preset-chip').forEach((c, i) => {
    c.classList.toggle('active', i === idx);
  });

  // ilo pane lags 150ms
  setTimeout(() => {
    const iloText = isMultiLine ? p.iloMulti : p.iloInline;
    iloRawText = iloText;
    iloCode.innerHTML = highlightIlo(iloText);
    updateStats();
  }, 150);

  // Reset output/error
  outputDiv.style.display = 'none';
  errorDiv.style.display = 'none';
  errorDiv.textContent = '';

  updateStats();
  toggleBtn.removeAttribute('disabled');
}

function toggleMode() {
  if (isApiResult) return;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  isMultiLine = !isMultiLine;
  toggleLabel.textContent = isMultiLine ? 'multi-line' : 'compact';
  const p = PRESETS[activePreset];
  setIloText(isMultiLine ? p.iloMulti : p.iloInline, !reduced);
}

toggleBtn.addEventListener('click', toggleMode);

// Auto-cycle every 8s, pause on hover
function resetAutoCycle() {
  if (autoCycleTimer) clearTimeout(autoCycleTimer);
  autoCycleTimer = null;
}

function scheduleAutoCycle() {
  resetAutoCycle();
  autoCycleTimer = setTimeout(() => {
    const next = (activePreset + 1) % PRESETS.length;
    loadPreset(next, true);
    scheduleAutoCycle();
  }, 8000);
}

const siaCard = document.querySelector('.sia-card');
siaCard?.addEventListener('mouseenter', resetAutoCycle);
siaCard?.addEventListener('mouseleave', scheduleAutoCycle);

// Editable Python — debounced stats update (500ms)
pyEl.removeAttribute('readonly');
pyEl.addEventListener('input', () => {
  // Re-highlight on every keystroke (cheap)
  pyHighlight.innerHTML = highlightPy(pyEl.value);
  if (debounceTimer) clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => {
    // Update python stats then auto-convert
    const py = pyEl.value;
    const pyTok = countTokens(py);
    const pyChar = py.length;
    animateCounter(pyTokensEl, prevPyTok, pyTok);
    animateCounter(pyCharsEl, prevPyChar, pyChar);
    prevPyTok = pyTok;
    prevPyChar = pyChar;
    runConvert();
  }, 800);
  resetAutoCycle();
});

// In-memory cache: sha256(python) → ilo result string
const convertCache = new Map<string, string>();
let lastConvertedHash = '';

async function sha256hex(text: string): Promise<string> {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
}

// Shared convert routine — debounced input calls this.
// Sequence counter lets a newer keystroke supersede a slow in-flight request.
let convertSeq = 0;
async function runConvert() {
  const python = pyEl.value.trim();
  if (!python) return;

  const hash = await sha256hex(python);
  if (hash === lastConvertedHash) return; // unchanged from last successful conversion

  // Cache hit
  if (convertCache.has(hash)) {
    lastConvertedHash = hash;
    isApiResult = true;
    setIloText(convertCache.get(hash)!);
    toggleBtn.setAttribute('disabled', 'true');
    isMultiLine = true;
    toggleLabel.textContent = 'multi-line';
    errorDiv.style.display = 'none';
    return;
  }

  const seq = ++convertSeq;

  resetAutoCycle();
  convertingOverlay.style.display = 'flex';
  errorDiv.style.display = 'none';
  outputDiv.style.display = 'none';

  try {
    const resp = await fetch('https://convert.ilo-lang.ai/convert', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ python }),
    });
    if (seq !== convertSeq) return;
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const data = await resp.json();
    const iloResult = data.ilo || data.result || data.code || '';
    if (!iloResult) throw new Error('Empty response');
    convertCache.set(hash, iloResult);
    lastConvertedHash = hash;
    isApiResult = true;
    setIloText(iloResult);
    toggleBtn.setAttribute('disabled', 'true');
    isMultiLine = true;
    toggleLabel.textContent = isMultiLine ? 'multi-line' : 'compact';
  } catch (err) {
    if (seq !== convertSeq) return;
    const fallback = PRESETS[activePreset];
    setIloText(isMultiLine ? fallback.iloMulti : fallback.iloInline);
    errorDiv.textContent = `Conversion unavailable — showing preset. (${(err as Error).message})`;
    errorDiv.style.display = 'block';
  } finally {
    if (seq === convertSeq) {
      convertingOverlay.style.display = 'none';
    }
  }
}

// Build preset chips
const presetsContainer = document.getElementById('demo-presets')!;
PRESETS.forEach((p, i) => {
  const chip = document.createElement('button');
  chip.className = 'sia-preset-chip' + (i === 0 ? ' active' : '');
  chip.textContent = p.name;
  chip.addEventListener('click', () => loadPreset(i));
  presetsContainer.appendChild(chip);
});

// Init
loadPreset(0, true);
scheduleAutoCycle();
</script>

