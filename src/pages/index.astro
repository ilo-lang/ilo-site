<script>
  // Tab switching
  const tabBtns = document.querySelectorAll('.tab-btn');
  const cmdTexts = document.querySelectorAll('.terminal-text[data-cmd]');
  const prompt = document.querySelector('.terminal-prompt') as HTMLElement;
  let activeTab = 'mac';

  const prompts: Record<string, string> = { mac: '$', windows: '>', claude: '>' };
  const commands: Record<string, string> = {
    mac: 'curl -fsSL https://raw.githubusercontent.com/ilo-lang/ilo/main/install.sh | sh',
    windows: 'irm https://raw.githubusercontent.com/ilo-lang/ilo/main/install.ps1 | iex',
    claude: '/plugin marketplace add ilo-lang/ilo && /plugin install ilo-lang/ilo',
  };

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      activeTab = tab;
      tabBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      cmdTexts.forEach((t) => {
        (t as HTMLElement).style.display = (t as HTMLElement).dataset.cmd === tab ? '' : 'none';
      });
      if (prompt) prompt.textContent = prompts[tab] || '$';
    });
  });

  // Copy to clipboard
  const copyBtn = document.getElementById('copy-btn');
  const terminal = document.getElementById('install-cmd');

  function handleCopy() {
    navigator.clipboard.writeText(commands[activeTab] || commands.mac);
    const iconCopy = copyBtn?.querySelector('.icon-copy') as HTMLElement;
    const iconCheck = copyBtn?.querySelector('.icon-check') as HTMLElement;
    if (iconCopy && iconCheck) {
      iconCopy.style.display = 'none';
      iconCheck.style.display = 'block';
      setTimeout(() => {
        iconCopy.style.display = 'block';
        iconCheck.style.display = 'none';
      }, 2000);
    }
  }

  copyBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    handleCopy();
  });
  terminal?.addEventListener('click', handleCopy);

  // (examples tab switching removed — section merged)

  // Scroll animations: enable only after JS is ready
  document.documentElement.classList.add('animate-ready');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
</script>

<script>
// ===== SEE IT IN ACTION — merged interactive demo =====

// Token approximation (cl100k_base proxy)
function countTokens(text: string): number {
  if (!text.trim()) return 0;
  return text.split(/([^\w])/u).filter(p => p.trim().length > 0).length;
}

// Animated counter roll (~400ms ease-out)
function animateCounter(el: HTMLElement, from: number, to: number) {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced || from === to) { el.textContent = String(to); return; }
  const dur = 400;
  const start = performance.now();
  function step(now: number) {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic
    el.textContent = String(Math.round(from + (to - from) * ease));
    if (t < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

interface Preset {
  name: string;
  python: string;
  iloMulti: string;    // multi-line form
  iloInline: string;   // one-liner semicolon form
  output: string;
}

const PRESETS: Preset[] = [
  {
    name: 'fib',
    python: `def fib(n: int) -> int:
    if n <= 1:
        return n
    return fib(n - 1) + fib(n - 2)

print(fib(10))`,
    iloMulti: `fib n:n>n
  <=n 1 n
  +fib -n 1 fib -n 2

main>n;fib 10`,
    iloInline: `fib n:n>n;<=n 1 n;+fib -n 1 fib -n 2\nmain>n;fib 10`,
    output: '55',
  },
  {
    name: 'fizzbuzz',
    python: `for i in range(1, 16):
    if i % 15 == 0:
        print("FizzBuzz")
    elif i % 3 == 0:
        print("Fizz")
    elif i % 5 == 0:
        print("Buzz")
    else:
        print(i)`,
    iloMulti: `fb i:n>t
  =(mod i 15) 0 "FizzBuzz"
  =(mod i 3) 0 "Fizz"
  =(mod i 5) 0 "Buzz"
  str i

main>_
  @i 1..16{prnt fb i}`,
    iloInline: `fb i:n>t;=(mod i 15) 0 "FizzBuzz";=(mod i 3) 0 "Fizz";=(mod i 5) 0 "Buzz";str i\nmain>_;@i 1..16{prnt fb i}`,
    output: '1\n2\nFizz\n4\nBuzz\nFizz\n7\n8\nFizz\nBuzz\n11\nFizz\n13\n14\nFizzBuzz',
  },
  {
    name: 'parse-csv',
    python: `def parse_csv(text: str) -> list:
    rows = text.strip().split("\\n")
    return [row.split(",") for row in rows]

data = parse_csv("a,b,c\\n1,2,3\\n4,5,6")
print(data[1][0])`,
    iloMulti: `parse-csv s:t>L L t
  rows=spl s "\\n"
  map (r:t>L t;spl r ",") rows

main>t
  d=parse-csv "a,b,c\\n1,2,3\\n4,5,6"
  at (at d 1) 0`,
    iloInline: `parse-csv s:t>L L t;map (r:t>L t;spl r ",") spl s "\\n"\nmain>t;d=parse-csv "a,b,c\\n1,2,3\\n4,5,6";at (at d 1) 0`,
    output: '1',
  },
  {
    name: 'fold-sum',
    python: `from functools import reduce

def add(a: float, b: float) -> float:
    return a + b

nums = [1, 2, 3, 4, 5]
total = reduce(add, nums, 0)
print(total)`,
    iloMulti: `add a:n b:n>n
  +a b

main>n
  fld add [1,2,3,4,5] 0`,
    iloInline: `add a:n b:n>n;+a b\nmain>n;fld add [1,2,3,4,5] 0`,
    output: '15',
  },
  {
    name: 'pipes',
    python: `def double(x: int) -> int:
    return x * 2

def increment(x: int) -> int:
    return x + 1

def run(x: int) -> int:
    return increment(double(x))

print(run(5))`,
    iloMulti: `dbl x:n>n;*x 2
inc x:n>n;+x 1
rn x:n>n;x>>dbl>>inc

main>n;rn 5`,
    iloInline: `dbl x:n>n;*x 2\ninc x:n>n;+x 1\nrn x:n>n;x>>dbl>>inc\nmain>n;rn 5`,
    output: '11',
  },
  {
    name: 'classify',
    python: `def classify(score: int) -> str:
    if score >= 90:
        return "A"
    elif score >= 80:
        return "B"
    elif score >= 70:
        return "C"
    else:
        return "F"

print(classify(85))`,
    iloMulti: `classify s:n>t
  >=s 90 "A"
  >=s 80 "B"
  >=s 70 "C"
  "F"

main>t;classify 85`,
    iloInline: `classify s:n>t;>=s 90 "A";>=s 80 "B";>=s 70 "C";"F"\nmain>t;classify 85`,
    output: 'B',
  },
];

let activePreset = 0;
let isMultiLine = true;
let isApiResult = false;
let autoCycleTimer: ReturnType<typeof setTimeout> | null = null;
let debounceTimer: ReturnType<typeof setTimeout> | null = null;
let prevPyTok = 0;
let prevPyChar = 0;
let prevIloTok = 0;
let prevIloChar = 0;

const pyEl = document.getElementById('demo-python') as HTMLTextAreaElement;
const iloEl = document.getElementById('demo-ilo') as HTMLTextAreaElement;
const pyTokensEl = document.getElementById('py-tokens')!;
const pyCharsEl = document.getElementById('py-chars')!;
const iloTokensEl = document.getElementById('ilo-tokens')!;
const iloCharsEl = document.getElementById('ilo-chars')!;
const diffEl = document.getElementById('sia-diff')!;
const outputDiv = document.getElementById('demo-output')!;
const outputText = document.getElementById('demo-output-text')!;
const errorDiv = document.getElementById('sia-error')!;
const convertBtn = document.getElementById('sia-convert-btn')!;
const convertingOverlay = document.getElementById('sia-converting')!;
const toggleBtn = document.getElementById('sia-toggle')!;
const toggleLabel = document.getElementById('sia-toggle-label')!;

function updateStats() {
  const py = pyEl.value;
  const ilo = iloEl.value;
  const pyTok = countTokens(py);
  const iloTok = countTokens(ilo);
  const pyChar = py.length;
  const iloChar = ilo.length;

  animateCounter(pyTokensEl, prevPyTok, pyTok);
  animateCounter(pyCharsEl, prevPyChar, pyChar);
  animateCounter(iloTokensEl, prevIloTok, iloTok);
  animateCounter(iloCharsEl, prevIloChar, iloChar);

  prevPyTok = pyTok;
  prevPyChar = pyChar;
  prevIloTok = iloTok;
  prevIloChar = iloChar;

  if (pyTok > 0 && iloTok > 0) {
    const pct = Math.round((1 - iloTok / pyTok) * 100);
    diffEl.textContent = `-${pct}% tokens`;
    diffEl.classList.remove('bounce');
    void diffEl.offsetWidth; // reflow
    diffEl.classList.add('bounce');
  } else {
    diffEl.textContent = '';
  }
}

function setIloText(text: string, animate = true) {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!animate || reduced) {
    iloEl.value = text;
    updateStats();
    return;
  }
  iloEl.classList.add('is-fading');
  setTimeout(() => {
    iloEl.value = text;
    iloEl.classList.remove('is-fading');
    updateStats();
  }, 150);
}

function loadPreset(idx: number, skipAutoCycle = false) {
  if (!skipAutoCycle) resetAutoCycle();
  activePreset = idx;
  isApiResult = false;
  const p = PRESETS[idx];

  pyEl.value = p.python;
  document.querySelectorAll('.sia-preset-chip').forEach((c, i) => {
    c.classList.toggle('active', i === idx);
  });

  // ilo pane lags 150ms
  setTimeout(() => {
    iloEl.value = isMultiLine ? p.iloMulti : p.iloInline;
    updateStats();
  }, 150);

  // Reset output/error
  outputDiv.style.display = 'none';
  errorDiv.style.display = 'none';
  errorDiv.textContent = '';

  updateStats();
  toggleBtn.removeAttribute('disabled');
}

function toggleMode() {
  if (isApiResult) return;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  isMultiLine = !isMultiLine;
  toggleLabel.textContent = isMultiLine ? 'multi-line' : 'inline';
  const p = PRESETS[activePreset];
  setIloText(isMultiLine ? p.iloMulti : p.iloInline, !reduced);
}

toggleBtn.addEventListener('click', toggleMode);

// Auto-cycle every 8s, pause on hover
function resetAutoCycle() {
  if (autoCycleTimer) clearTimeout(autoCycleTimer);
  autoCycleTimer = null;
}

function scheduleAutoCycle() {
  resetAutoCycle();
  autoCycleTimer = setTimeout(() => {
    const next = (activePreset + 1) % PRESETS.length;
    loadPreset(next, true);
    scheduleAutoCycle();
  }, 8000);
}

const siaCard = document.querySelector('.sia-card');
siaCard?.addEventListener('mouseenter', resetAutoCycle);
siaCard?.addEventListener('mouseleave', scheduleAutoCycle);

// Editable Python — debounced stats update (500ms)
pyEl.removeAttribute('readonly');
pyEl.addEventListener('input', () => {
  if (debounceTimer) clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => {
    // update python stats immediately; ilo stays as-is until Convert
    const py = pyEl.value;
    const pyTok = countTokens(py);
    const pyChar = py.length;
    animateCounter(pyTokensEl, prevPyTok, pyTok);
    animateCounter(pyCharsEl, prevPyChar, pyChar);
    prevPyTok = pyTok;
    prevPyChar = pyChar;
  }, 500);
  resetAutoCycle();
});

// Convert button
convertBtn.addEventListener('click', async () => {
  const python = pyEl.value.trim();
  if (!python) return;

  resetAutoCycle();
  (convertBtn as HTMLButtonElement).disabled = true;
  convertingOverlay.style.display = 'flex';
  errorDiv.style.display = 'none';
  outputDiv.style.display = 'none';

  try {
    const resp = await fetch('https://convert.ilo-lang.ai/convert', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ python }),
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const data = await resp.json();
    const iloCode = data.ilo || data.result || data.code || '';
    if (!iloCode) throw new Error('Empty response');
    isApiResult = true;
    setIloText(iloCode);
    toggleBtn.setAttribute('disabled', 'true');
    isMultiLine = true;
    toggleLabel.textContent = 'multi-line';
  } catch (err) {
    // Fallback: show last preset
    const fallback = PRESETS[activePreset];
    setIloText(isMultiLine ? fallback.iloMulti : fallback.iloInline);
    errorDiv.textContent = `Conversion unavailable — showing preset. (${(err as Error).message})`;
    errorDiv.style.display = 'block';
  } finally {
    (convertBtn as HTMLButtonElement).disabled = false;
    convertingOverlay.style.display = 'none';
  }
});

// Build preset chips
const presetsContainer = document.getElementById('demo-presets')!;
PRESETS.forEach((p, i) => {
  const chip = document.createElement('button');
  chip.className = 'sia-preset-chip' + (i === 0 ? ' active' : '');
  chip.textContent = p.name;
  chip.addEventListener('click', () => loadPreset(i));
  presetsContainer.appendChild(chip);
});

// Init
loadPreset(0, true);
scheduleAutoCycle();
</script>

