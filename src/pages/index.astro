  }
  .feat h3 {
    font-family: var(--ilo-font-sans);
    font-size: 20px; font-weight: 700;
    color: var(--ilo-fg-1); margin: 0;
    letter-spacing: -0.02em;
  }
  .feat p {
    font-family: var(--ilo-font-sans);
    font-size: 14px; color: var(--ilo-fg-3);
