// Token approximation (cl100k_base proxy)
function countTokens(text: string): number {
  if (!text.trim()) return 0;
  return text.split(/([^\w])/u).filter(p => p.trim().length > 0).length;
}

// Animated counter roll (~400ms ease-out)
function animateCounter(el: HTMLElement, from: number, to: number) {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced || from === to) { el.textContent = String(to); return; }
  const dur = 400;
  const start = performance.now();
  function step(now: number) {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic
    el.textContent = String(Math.round(from + (to - from) * ease));
    if (t < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

