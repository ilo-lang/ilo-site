---
// Custom landing page - bypasses Starlight entirely.
// Implements the design system handoff (ilo-design-system v1).
import BaseHead from '../components/BaseHead.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_URL, softwareApplicationSchema, websiteSchema } from '../lib/schema';
import '../styles/global.css';

const principles = [
  { n: '01', name: 'Token-Conservative', body: 'Every choice evaluated against total token cost — generation, errors, retries, context loading. Prefix notation. Single-char names. Guards instead of nested if/else.', href: '/docs/learn/manifesto/#1-token-conservative' },
  { n: '02', name: 'Constrained',         body: 'Small vocabulary, closed world. Every callable function is known ahead of time. The agent cannot hallucinate an API. Fewer valid next-tokens means fewer retries.', href: '/docs/learn/manifesto/#2-constrained' },
  { n: '03', name: 'Self-Contained',      body: 'Each unit carries its own context: deps, types, rules. The less context required per step, the more of the window is available for the actual task.', href: '/docs/learn/manifesto/#3-self-contained' },
  { n: '04', name: 'Language-Agnostic',   body: 'Minimise dependency on English. Single-char sigils outperform keywords. Agents learn the full vocabulary from spec + examples with 10/10 accuracy.', href: '/docs/learn/manifesto/#4-language-agnostic' },
  { n: '05', name: 'Graph-Reducible',     body: 'The dependency graph is explicit and queryable. ilo graph extracts call graphs, types, callers as JSON. Modify one function, load 6–10% of the code.', href: '/docs/learn/manifesto/#5-graph-reducible' },
  { n: '06', name: 'Structured Surface',  body: 'Every CLI subcommand has --json. Every diagnostic carries an error code, source span, and FixSafety. Zero screen-scraping, zero retry cycles from format ambiguity.', href: '/docs/learn/manifesto/#6-structured-compiler-to-agent-surface' },
];

const shipped = [
  { tag: 'language',  name: 'Sum types',       body: 'Discriminated unions with generics, recursive variants, exhaustive match.' },
  { tag: 'language',  name: 'Generics',        body: 'Bounded and multi-bound type variables across functions.' },
  { tag: 'language',  name: 'Brace-lambda',    body: 'Multi-statement lambda bodies: { |x:n>n; s=*x x; +s 1| }' },
  { tag: 'compiler',  name: 'Cranelift TCO',   body: 'Tail-call optimisation via return_call in the JIT. Recursion is now free.' },
  { tag: 'runtime',   name: 'par-map',         body: 'Parallel map with chunking and a native VM opcode for the common case.' },
  { tag: 'runtime',   name: 'WASM HTTP fetch', body: '$url works inside WASM builds — Node, the browser, Cowork.' },
  { tag: 'tooling',   name: 'ilo trace',       body: 'Execution trace with per-step timing, JSON output by default.' },
  { tag: 'tooling',   name: 'Fix plans',       body: 'ilo apply applies structured repair plans from ilo check --json.' },
  { tag: 'ecosystem', name: 'Package registry',body: 'ilo add installs packages from the registry. Reproducible.' },
  { tag: 'ecosystem', name: 'ilo httpd',       body: 'Serve functions as HTTP endpoints. One command, no framework.' },
];

const installPaths = [
  { id: 'humans', label: 'For humans', hint: 'curl', cmd: 'curl -fsSL ilo-lang.ai/install.sh | sh' },
  { id: 'agents', label: 'For agents', hint: 'mcp',  cmd: 'claude mcp add ilo-lang/ilo' },
];

const benchmarks = [
  { lang: 'Rust',     ns: 329,   tag: 'native',     ilo: false },
  { lang: 'LuaJIT',   ns: 442,   tag: 'JIT',        ilo: false },
  { lang: 'Node/V8',  ns: 451,   tag: 'JIT',        ilo: false },
  { lang: 'Kotlin',   ns: 528,   tag: 'JVM',        ilo: false },
  { lang: 'Go',       ns: 665,   tag: 'native',     ilo: false },
  { lang: 'PyPy 3',   ns: 1500,  tag: 'JIT',        ilo: false },
  { lang: 'ilo JIT',  ns: 4200,  tag: 'Cranelift',  ilo: true  },
  { lang: 'ilo AOT',  ns: 5300,  tag: 'Cranelift',  ilo: true  },
  { lang: 'PHP',      ns: 6700,  tag: 'interp',     ilo: false },
  { lang: 'ilo VM',   ns: 14700, tag: 'bytecode',   ilo: true  },
  { lang: 'Python 3', ns: 29500, tag: 'interp',     ilo: false },
];
const benchMax = Math.max(...benchmarks.map(r => r.ns));
const fmt = (ns: number) => ns >= 1000 ? `${(ns / 1000).toFixed(1)}µs` : `${ns}ns`;
---

<html lang="en">
<head>
  <BaseHead
    title="ilo | AI Agent Language"
    description="0.33× the tokens, 0.22× the characters of Python. Type-verified before execution. A programming language with LLMs as the intended author."
  />
  <link rel="canonical" href={SITE_URL} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={SITE_URL} />
  <meta property="og:title" content="ilo | AI Agent Language" />
  <meta property="og:description" content="Token-optimised programming language for AI agents. 0.33× the tokens of Python. Type-verified before execution." />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="ilo | AI Agent Language" />
  <meta name="twitter:description" content="Token-optimised programming language for AI agents. 0.33× the tokens of Python. Type-verified before execution." />
  <JsonLd data={softwareApplicationSchema} />
  <JsonLd data={websiteSchema} />
</head>
<body>

  <!-- TOP NAV -->
  <header class="topnav">
    <div class="container-wide topnav-inner">
      <a href="/" class="brand">
        <span class="brand-mark">ilo</span>
        <span class="brand-version">v0.13.0</span>
      </a>
      <nav class="nav-links">
        <a href="/docs/introduction/">Docs</a>
        <a href="/docs/learn/manifesto/">Manifesto</a>
        <a href="#install">Install</a>
        <a href="#benchmarks">Benchmarks</a>
      </nav>
      <div class="nav-spacer"></div>
      <a class="nav-github" href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        <span>GitHub</span>
      </a>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container-wide hero-grid">
        <div class="hero-left">
          <div class="kicker">Programming language · for AI agents</div>
          <h1 class="hero-title">
            The fewest tokens from intent to <span class="accent">working code.</span>
          </h1>
          <p class="hero-lede">
            ilo is a token-optimised language designed for the brain that produces code: an LLM.
            Prefix notation, single-character variables, type-verified before execution.
            One metric: <em>total cost from intent to working code.</em>
          </p>

          <div class="install-pill">
            <div class="install-pill-cmd">
              <span class="dollar">$</span> curl -fsSL ilo-lang.ai/install.sh | sh
            </div>
            <button class="install-pill-copy" id="hero-copy" aria-label="Copy install command">
              <svg class="ic-copy" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="ic-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="label">copy</span>
            </button>
          </div>

          <div class="hero-actions">
            <a href="/docs/introduction/" class="btn btn-primary">
              Get started
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/docs/learn/manifesto/" class="btn btn-ghost">Read the manifesto</a>
            <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="btn-text license">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              MIT &amp; Apache-2.0
            </a>
          </div>
        </div>

        <div class="hero-right">
          <div class="frame frame-muted">
            <div class="frame-title">
              <span>python · script.py</span>
              <span class="mono">30 tokens · 93 chars</span>
            </div>
            <pre class="frame-body"><span class="kw">def</span> tot(p<span class="op">:</span> <span class="op">float</span>, q<span class="op">:</span> <span class="op">float</span>, r<span class="op">:</span> <span class="op">float</span>) <span class="op">-&gt;</span> <span class="op">float</span>:
    s <span class="op">=</span> p <span class="op">*</span> q
    t <span class="op">=</span> s <span class="op">*</span> r
    <span class="kw">return</span> s <span class="op">+</span> t</pre>
          </div>
          <div class="frame">
            <div class="frame-title">
              <span>ilo · script.@</span>
              <span class="mono">10 tokens · 38 chars</span>
            </div>
            <pre class="frame-body"><span class="kw">tot</span> p<span class="op">:n</span> q<span class="op">:n</span> r<span class="op">:n</span><span class="op">&gt;n</span>
  s<span class="op">=*</span>p q
  t<span class="op">=*</span>s r
  <span class="op">+</span>s t</pre>
          </div>
          <div class="stat-hero">
            <div class="stat-nums">
              <span>python <b>30</b> tokens</span>
              <span class="arrow">→</span>
              <span>ilo <b>10</b> tokens</span>
            </div>
            <span class="pill pill-lime">−67% tokens</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section id="manifesto" class="principles">
      <div class="container-wide">
        <div class="section-head">
          <div class="kicker">The Six Principles</div>
          <h2>Every design decision is evaluated against one number.</h2>
          <p class="sub">If a feature reduces total tokens from intent to working code, it's in. If it increases it, it's out. No exceptions for elegance, readability, or convention.</p>
        </div>
        <div class="principles-grid">
          {principles.map((it) => (
            <a class="principle" href={it.href}>
              <div class="principle-meta">
                <span class="mono num">{it.n}</span>
                <span class="ekicker">principle</span>
              </div>
              <h3>{it.name}</h3>
              <p>{it.body}</p>
            </a>
          ))}
        </div>
        <div class="principles-cta">
          <a class="btn-text" href="/docs/learn/manifesto/">
            Read the full manifesto
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- SHIPPED -->
    <section id="shipped" class="shipped">
      <div class="container-wide">
        <div class="section-head">
          <div class="kicker">v0.13.0 · largest release since 0.10</div>
          <h2>Sum types, generics, package registry, Cranelift TCO.</h2>
          <p class="sub">A focused release: closing the gap on language expressivity (sum types, generics, brace-lambdas) while keeping the token cost flat.</p>
        </div>
        <div class="shipped-grid">
          {shipped.map((it) => (
            <div class="ship-card">
              <div class="ship-head">
                <span class="ship-name">{it.name}</span>
                <span class="mono ship-tag">{it.tag}</span>
              </div>
              <p>{it.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- INSTALL -->
    <section id="install" class="install">
      <div class="container-wide install-wrap">
        <div class="section-head">
          <div class="kicker">Install</div>
          <h2>Two paths. One binary.</h2>
          <p class="sub">One-line shell installer for humans. MCP registration for agents. Native binary on Linux, macOS, Windows; WASM via npm. The rest live in the docs.</p>
        </div>

        <div class="install-block">
          <div class="install-tabs" role="tablist">
            {installPaths.map((p, i) => (
              <button class={`install-tab${i === 0 ? ' active' : ''}`} role="tab" data-install-tab={p.id} aria-selected={i === 0}>
                <span>{p.label}</span>
                <span class="hint mono">{p.hint}</span>
              </button>
            ))}
          </div>
          {installPaths.map((p, i) => (
            <div class={`install-term${i === 0 ? ' active' : ''}`} data-install-panel={p.id}>
              <div class="install-term-body">
                <span class="dollar">$</span> {p.cmd}
              </div>
              <button class="install-term-copy frame-copy" data-copy={p.cmd} aria-label={`Copy ${p.label} install command`}>copy</button>
            </div>
          ))}
        </div>

        <div class="install-verify">
          Verify it works: <code>ilo 'dbl x:n&gt;n;*x 2' 5</code> → <span class="mono accent">10</span>
          <a class="btn-text install-more" href="/docs/learn/install/">
            All install paths
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- BENCHMARKS -->
    <section id="benchmarks" class="benchmarks">
      <div class="container-wide">
        <div class="section-head">
          <div class="kicker">Honest benchmarks</div>
          <h2>Three engines. None of them is the fastest. That's not the metric.</h2>
          <p class="sub">
            ilo runs on a bytecode VM, a Cranelift JIT, and a Cranelift AOT compiler.
            They sit in the middle of the runtime field — faster than Python or Ruby, slower than V8 or Go.
            The number that matters is the one above the keyboard, not the one below it.
          </p>
        </div>
        <div class="bench-card">
          <div class="bench-head">
            <span>numeric · sum 1..1000 · median ns/call · 10000 iterations</span>
            <span>Darwin arm64 · 2026-03-13</span>
          </div>
          <div class="bench-body">
            {benchmarks.map((r) => (
              <div class={`bench-row${r.ilo ? ' ilo' : ''}`}>
                <span class="bench-lang">{r.lang}</span>
                <span class="mono bench-tag">{r.tag}</span>
                <div class="bench-bar">
                  <div class="bench-fill" style={`width:${(r.ns / benchMax) * 100}%`}></div>
                </div>
                <span class="mono bench-ns">{fmt(r.ns)}</span>
              </div>
            ))}
          </div>
          <div class="bench-foot">
            <span>7 more benchmarks in the full table — string, record, mixed, foreach, recurse…</span>
            <a class="btn-text" href="/docs/reference/benchmarks/">
              All benchmarks
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="ilo-footer">
    <div class="container-wide">
      <div class="footer-grid">
        <div class="footer-brand">
          <span class="footer-mark">ilo</span>
          <p>Token-optimised programming language for AI agents. Open source under MIT &amp; Apache-2.0. Toki Pona for &ldquo;tool&rdquo;.</p>
        </div>
        <div class="footer-col">
          <div class="footer-head">Learn</div>
          <a href="/docs/introduction/">Introduction</a>
          <a href="/docs/learn/manifesto/">Manifesto</a>
          <a href="/docs/learn/install/">Install</a>
          <a href="/docs/learn/examples/">Examples</a>
        </div>
        <div class="footer-col">
          <div class="footer-head">Reference</div>
          <a href="/docs/reference/language/">Language</a>
          <a href="/docs/reference/cli/">CLI</a>
          <a href="/docs/reference/diagnostics/">Diagnostics</a>
          <a href="/docs/reference/benchmarks/">Benchmarks</a>
        </div>
        <div class="footer-col">
          <div class="footer-head">Builtins</div>
          <a href="/docs/reference/builtins/">All builtins</a>
          <a href="/docs/reference/builtins/#numbers">Numbers</a>
          <a href="/docs/reference/builtins/#text">Text</a>
          <a href="/docs/reference/builtins/#http">HTTP</a>
        </div>
        <div class="footer-col">
          <div class="footer-head">Community</div>
          <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.reddit.com/r/ilolang/" target="_blank" rel="noopener">Reddit</a>
          <a href="https://github.com/ilo-lang/ilo/releases" target="_blank" rel="noopener">Releases</a>
          <a href="/contact/">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="mono">v0.13.0 · MIT &amp; Apache-2.0</span>
        <span class="mono">built with ilo</span>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  // Hero install command copy
  const heroCopy = document.getElementById('hero-copy');
  if (heroCopy) {
    heroCopy.addEventListener('click', () => {
      navigator.clipboard?.writeText('curl -fsSL ilo-lang.ai/install.sh | sh');
      const cp = heroCopy.querySelector('.ic-copy') as HTMLElement | null;
      const ck = heroCopy.querySelector('.ic-check') as HTMLElement | null;
      const lbl = heroCopy.querySelector('.label') as HTMLElement | null;
      if (cp) cp.style.display = 'none';
      if (ck) ck.style.display = '';
      if (lbl) lbl.textContent = 'copied';
      heroCopy.classList.add('done');
      setTimeout(() => {
        if (cp) cp.style.display = '';
        if (ck) ck.style.display = 'none';
        if (lbl) lbl.textContent = 'copy';
        heroCopy.classList.remove('done');
      }, 1400);
    });
  }

  // Install tab switching (For humans / For agents)
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-install-tab]');
  const terms = document.querySelectorAll<HTMLElement>('[data-install-panel]');
  tabs.forEach(t => {
    t.addEventListener('click', () => {
      const id = t.getAttribute('data-install-tab');
      tabs.forEach(x => {
        const on = x === t;
        x.classList.toggle('active', on);
        x.setAttribute('aria-selected', String(on));
      });
      terms.forEach(p => p.classList.toggle('active', p.getAttribute('data-install-panel') === id));
    });
  });

  // Per-panel copy buttons
  document.querySelectorAll<HTMLButtonElement>('.frame-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-copy') || '';
      navigator.clipboard?.writeText(cmd);
      const orig = btn.textContent;
      btn.textContent = 'copied';
      btn.classList.add('done');
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove('done');
      }, 1400);
    });
  });
</script>

<style>
  /* ===== reset ===== */
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--ilo-ink-0); color: var(--ilo-fg-1); font-family: var(--ilo-font-sans); -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  a { color: var(--ilo-accent); text-decoration: none; transition: color var(--ilo-duration-1) var(--ilo-ease); }
  a:hover { color: var(--ilo-amber-high); }
  ::selection { background: rgba(224, 148, 34, 0.3); color: var(--ilo-fg-1); }
  em { font-style: normal; color: var(--ilo-fg-1); }
  h1, h2, h3, p { margin: 0; }

  .container-wide { width: 100%; max-width: var(--ilo-container-wide); margin: 0 auto; padding: 0 28px; }
  .mono { font-family: var(--ilo-font-mono); font-variant-ligatures: none; }
  .accent { color: var(--ilo-accent); }

  /* ===== top nav ===== */
  .topnav {
    position: sticky; top: 0; z-index: 10;
    background: var(--ilo-ink-nav);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ilo-hairline);
  }
  .topnav-inner { display: flex; align-items: center; gap: 28px; height: 60px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; }
  .brand-mark { font-family: var(--ilo-font-sans); font-weight: 800; font-size: 22px; letter-spacing: -0.02em; color: var(--ilo-accent); line-height: 1; }
  .brand-version { font-family: var(--ilo-font-mono); font-size: 11px; padding: 2px 7px; border-radius: 999px; color: var(--ilo-accent); background: rgba(224, 148, 34, 0.10); border: 1px solid rgba(224, 148, 34, 0.22); }
  .nav-links { display: flex; gap: 22px; margin-left: 12px; }
  .nav-links a { color: var(--ilo-fg-3); font-size: 14px; }
  .nav-links a:hover { color: var(--ilo-fg-1); }
  .nav-spacer { flex: 1; }
  .nav-github { display: inline-flex; align-items: center; gap: 8px; color: var(--ilo-fg-3); font-size: 14px; }
  .nav-github:hover { color: var(--ilo-fg-1); }

  /* ===== hero ===== */
  .hero { position: relative; padding: 88px 0 64px; overflow: hidden; }
  .hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(900px 380px at 20% 30%, rgba(224, 148, 34, 0.10), transparent 60%);
  }
  .hero-grid { position: relative; display: grid; grid-template-columns: 1.05fr 1fr; gap: 56px; align-items: center; }
  .hero-left { display: flex; flex-direction: column; gap: 18px; }
  .kicker { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ilo-accent); font-weight: 500; }
  .hero-title { font-family: var(--ilo-font-sans); font-weight: 700; font-size: 68px; line-height: 1.02; letter-spacing: -0.035em; color: var(--ilo-fg-1); }
  .hero-title .accent { color: var(--ilo-accent); }
  .hero-lede { font-size: 18px; line-height: 1.55; color: var(--ilo-fg-3); max-width: 520px; }

  .install-pill {
    margin-top: 14px; display: flex; align-items: stretch;
    background: var(--ilo-ink-2);
