  .install-foot-link {
    font-family: var(--ilo-font-sans); font-size: 14px;
    color: var(--ilo-amber); text-decoration: none; font-weight: 500;
  }
  .install-foot-link span { font-family: var(--ilo-font-mono); margin-left: 4px; }
  .install-foot-link:hover { color: var(--ilo-amber-high); }

  /* Features */
  .features { padding: 100px 32px; border-bottom: 1px solid var(--ilo-hairline); }
  .features-grid {
    max-width: 1100px; margin: 56px auto 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  }
  .feat {
    padding: 24px 26px;
    border: 1px solid var(--ilo-hairline);
    border-radius: var(--ilo-radius-md);
    background: linear-gradient(180deg, rgba(255,255,255,0.012), transparent);
    display: flex; flex-direction: column; gap: 12px;
    text-decoration: none; color: inherit;
    transition: border-color var(--ilo-duration-2) var(--ilo-ease),
                background var(--ilo-duration-2) var(--ilo-ease);
  }
  .feat:hover {
    border-color: rgba(224, 148, 34, 0.30);
    background: linear-gradient(180deg, rgba(224, 148, 34, 0.045), transparent);
  }
  .feat .kicker {
    font-family: var(--ilo-font-sans);
    font-size: 10.5px; font-weight: 600;
    letter-spacing: 0.10em; text-transform: uppercase;
