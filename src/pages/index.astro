---
// Custom landing page - bypasses Starlight entirely.
// Implements the design system handoff (ilo-design-system v1).
import BaseHead from '../components/BaseHead.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_URL, softwareApplicationSchema, websiteSchema } from '../lib/schema';
import '../styles/global.css';

const principles = [
  { n: '01', name: 'Token-Conservative', body: 'Every choice evaluated against total token cost — generation, errors, retries, context loading. Prefix notation. Single-char names. Guards instead of nested if/else.', href: '/docs/learn/manifesto/#1-token-conservative' },
  { n: '02', name: 'Constrained',         body: 'Small vocabulary, closed world. Every callable function is known ahead of time. The agent cannot hallucinate an API. Fewer valid next-tokens means fewer retries.', href: '/docs/learn/manifesto/#2-constrained' },
  { n: '03', name: 'Self-Contained',      body: 'Each unit carries its own context: deps, types, rules. The less context required per step, the more of the window is available for the actual task.', href: '/docs/learn/manifesto/#3-self-contained' },
  { n: '04', name: 'Language-Agnostic',   body: 'Minimise dependency on English. Single-char sigils outperform keywords. Agents learn the full vocabulary from spec + examples with 10/10 accuracy.', href: '/docs/learn/manifesto/#4-language-agnostic' },
  { n: '05', name: 'Graph-Reducible',     body: 'The dependency graph is explicit and queryable. ilo graph extracts call graphs, types, callers as JSON. Modify one function, load 6–10% of the code.', href: '/docs/learn/manifesto/#5-graph-reducible' },
  { n: '06', name: 'Structured Surface',  body: 'Every CLI subcommand has --json. Every diagnostic carries an error code, source span, and FixSafety. Zero screen-scraping, zero retry cycles from format ambiguity.', href: '/docs/learn/manifesto/#6-structured-compiler-to-agent-surface' },
];

const shipped = [
  { tag: 'language',  name: 'Sum types',       body: 'Discriminated unions with generics, recursive variants, exhaustive match.' },
  { tag: 'language',  name: 'Generics',        body: 'Bounded and multi-bound type variables across functions.' },
  { tag: 'language',  name: 'Brace-lambda',    body: 'Multi-statement lambda bodies: { |x:n>n; s=*x x; +s 1| }' },
  { tag: 'compiler',  name: 'Cranelift TCO',   body: 'Tail-call optimisation via return_call in the JIT. Recursion is now free.' },
  { tag: 'runtime',   name: 'par-map',         body: 'Parallel map with chunking and a native VM opcode for the common case.' },
  { tag: 'runtime',   name: 'WASM HTTP fetch', body: '$url works inside WASM builds — Node, the browser, Cowork.' },
  { tag: 'tooling',   name: 'ilo trace',       body: 'Execution trace with per-step timing, JSON output by default.' },
  { tag: 'tooling',   name: 'Fix plans',       body: 'ilo apply applies structured repair plans from ilo check --json.' },
  { tag: 'ecosystem', name: 'Package registry',body: 'ilo add installs packages from the registry. Reproducible.' },
  { tag: 'ecosystem', name: 'ilo httpd',       body: 'Serve functions as HTTP endpoints. One command, no framework.' },
];

type InstallSub = { id: string; label: string; file: string; cmd: string };
type InstallGroup = { id: string; label: string; verify: string; verifyOut?: string; verifyNote?: string; subs: InstallSub[] };
const installGroups: InstallGroup[] = [
  {
    id: 'humans',
    label: 'For humans',
    verify: "ilo 'dbl x:n>n;*x 2' 5",
    verifyOut: '10',
    subs: [
      { id: 'mac',     label: 'macOS / Linux', file: 'install.sh',  cmd: 'curl -fsSL ilo-lang.ai/install.sh | sh' },
      { id: 'windows', label: 'Windows',       file: 'install.ps1', cmd: 'irm https://ilo-lang.ai/install.ps1 | iex' },
    ],
  },
  {
    id: 'agents',
    label: 'For agents',
    verify: 'tool: ilo',
    verifyNote: 'type-checked at load',
    subs: [
      { id: 'claude', label: 'Claude Code',  file: 'plugin.json', cmd: '/plugin marketplace add ilo-lang/ilo && /plugin install ilo-lang/ilo' },
      { id: 'pi',     label: 'Pi',           file: 'pi.json',  cmd: 'pi install ilo-lang/ilo' },
      { id: 'other',  label: 'Other agents', file: 'skills.json', cmd: 'npx skills add ilo-lang/ilo' },
    ],
  },
];

const benchmarks = [
  { lang: 'Rust',     ns: 329,   tag: 'native',     ilo: false },
  { lang: 'LuaJIT',   ns: 442,   tag: 'JIT',        ilo: false },
  { lang: 'Node/V8',  ns: 451,   tag: 'JIT',        ilo: false },
  { lang: 'Kotlin',   ns: 528,   tag: 'JVM',        ilo: false },
  { lang: 'Go',       ns: 665,   tag: 'native',     ilo: false },
  { lang: 'PyPy 3',   ns: 1500,  tag: 'JIT',        ilo: false },
  { lang: 'ilo JIT',  ns: 4200,  tag: 'Cranelift',  ilo: true  },
  { lang: 'ilo AOT',  ns: 5300,  tag: 'Cranelift',  ilo: true  },
  { lang: 'PHP',      ns: 6700,  tag: 'interp',     ilo: false },
  { lang: 'ilo VM',   ns: 14700, tag: 'bytecode',   ilo: true  },
  { lang: 'Python 3', ns: 29500, tag: 'interp',     ilo: false },
];
const benchMax = Math.max(...benchmarks.map(r => r.ns));
const fmt = (ns: number) => ns >= 1000 ? `${(ns / 1000).toFixed(1)}µs` : `${ns}ns`;
---

<html lang="en">
<head>
  <BaseHead
    title="ilo | AI Agent Language"
    description="0.33× the tokens, 0.22× the characters of Python. Type-verified before execution. A programming language with LLMs as the intended author."
  />
  <link rel="canonical" href={SITE_URL} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={SITE_URL} />
  <meta property="og:title" content="ilo | AI Agent Language" />
  <meta property="og:description" content="Token-optimised programming language for AI agents. 0.33× the tokens of Python. Type-verified before execution." />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="ilo | AI Agent Language" />
  <meta name="twitter:description" content="Token-optimised programming language for AI agents. 0.33× the tokens of Python. Type-verified before execution." />
  <JsonLd data={softwareApplicationSchema} />
  <JsonLd data={websiteSchema} />
</head>
<body>

  <!-- TOP NAV -->
  <header class="topnav">
    <div class="container-wide topnav-inner">
      <a href="/" class="brand">
        <span class="brand-mark">ilo</span>
        <span class="brand-version">v26.5</span>
      </a>
      <nav class="nav-links nav-links-page">
        <a href="#see-it-in-action">Try it yourself</a>
        <a href="#manifesto">Manifesto</a>
        <a href="#install">Install</a>
      </nav>
      <div class="nav-spacer"></div>
      <a class="nav-link-ext" href="/docs/introduction/">Docs</a>
      <a class="nav-github" href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        <span>GitHub</span>
      </a>
      <a class="btn btn-ghost nav-cta" href="#install">Install</a>
      <a class="btn btn-primary nav-cta" href="#see-it-in-action">Try it yourself</a>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container-wide hero-grid">
        <div class="hero-left">
          <h1 class="hero-title">
            Built for <span class="ai-prefix">AI </span>agents,<br><span class="accent">not humans.</span>
          </h1>
          <p class="hero-sub">The fewest tokens from intent to working code.</p>
          <p class="hero-lede">
            The first programming language designed from the ground up for LLM agents. The audience is not human. The vocabulary is small. The verifier runs before the program does. Errors arrive as JSON with fix plans attached. The metric is <em>total tokens spent</em>. Everything else is negotiable.
          </p>

        </div>

        <div class="hero-right">
          <div class="frame frame-muted">
            <div class="frame-title">
              <span>python · script.py</span>
              <span class="mono">30 tokens · 93 chars</span>
            </div>
            <pre class="frame-body"><span class="kw">def</span> tot(p<span class="op">:</span> <span class="op">float</span>, q<span class="op">:</span> <span class="op">float</span>, r<span class="op">:</span> <span class="op">float</span>) <span class="op">-&gt;</span> <span class="op">float</span>:
    s <span class="op">=</span> p <span class="op">*</span> q
    t <span class="op">=</span> s <span class="op">*</span> r
    <span class="kw">return</span> s <span class="op">+</span> t</pre>
          </div>
          <div class="frame">
            <div class="frame-title">
              <span>ilo · script.@</span>
              <span class="mono">10 tokens · 30 chars</span>
            </div>
            <pre class="frame-body"><span class="kw">tot</span> p<span class="op">:n</span> q<span class="op">:n</span> r<span class="op">:n</span><span class="op">&gt;n</span>;s<span class="op">=*</span>p q;t<span class="op">=*</span>s r;<span class="op">+</span>s t</pre>
          </div>
          <div class="stat-hero">
            <div class="stat-nums">
              <span>python <b>30</b> tokens</span>
              <span class="arrow">→</span>
              <span>ilo <b>10</b> tokens</span>
            </div>
            <span class="pill pill-lime">−67% tokens</span>
          </div>
          <a class="btn-text try-link" href="#see-it-in-action">
            Try it yourself
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- INSTALL -->
    <section id="install" class="install">
      <div class="container-wide install-wrap">
        <h2 class="install-h2"><span class="hash">#</span>install</h2>

        <div class="install-tabs" role="tablist">
          {installGroups.map((g, i) => (
            <button class={`install-tab${i === 0 ? ' active' : ''}`} role="tab" data-install-tab={g.id} aria-selected={i === 0}>
              {g.label}
            </button>
          ))}
        </div>

        {installGroups.map((g, gi) => (
          <div class={`install-group${gi === 0 ? ' active' : ''}`} data-install-group={g.id}>
            <div class="term-wrap">
              <div class="term">
                <div class="term-head">
                  {g.subs.map((s, j) => (
                    <span class={`term-file${j === 0 ? ' active' : ''}`} data-term-file={`${g.id}:${s.id}`}>{s.file}</span>
                  ))}
                  <label class="picker">
                    <select class="picker-select" data-install-picker={g.id}>
                      {g.subs.map((s) => (
                        <option value={`${g.id}:${s.id}`}>{s.label}</option>
                      ))}
                    </select>
                    <span class="chev" aria-hidden="true">▾</span>
                  </label>
                </div>
                {g.subs.map((s, j) => (
                  <div class={`term-body-wrap${j === 0 ? ' active' : ''}`} data-install-panel={`${g.id}:${s.id}`}>
                    <pre class="term-body"><span class="p">$</span> {s.cmd}</pre>
                    <button class="term-copy" data-copy={s.cmd} aria-label={`Copy ${g.label} ${s.label} install command`}>copy</button>
                  </div>
                ))}
              </div>
            </div>

            <div class="footer-row">
              <span class="verify-inline">
                {g.verifyOut ? (
                  <>
                    verify
                    <code>{g.verify}</code>
                    <span class="arrow">→</span>
                    <span class="out">{g.verifyOut}</span>
                    <span class="check">✓</span>
                  </>
                ) : (
                  <>
                    <code>{g.verify}</code>
                    <span class="arrow">·</span>
                    <span>{g.verifyNote}</span>
                    <span class="check">✓</span>
                  </>
                )}
              </span>
              <a class="more" href="/docs/learn/install/">
                {g.id === 'agents' ? 'All hosts →' : 'All install paths →'}
              </a>
            </div>
          </div>
        ))}

        <p class="evolving">
          <span class="evolving-tag">heads-up</span>
          ilo is actively evolving — today's syntax and builtins are not a contract. Expect breaking changes while the language searches for what works best for agents. Run it in a safe environment, not against production.
        </p>
      </div>
    </section>

    <!-- SEE IT IN ACTION (merged interactive demo) -->
    <section id="see-it-in-action" class="sia-section" data-animate>
      <div class="container-wide">
        <h2 class="section-title">Try it yourself</h2>
        <p class="section-subtitle">Edit the Python or click a preset. ilo is generated live with token and character counts.</p>

        <div class="sia-card">
          <div class="sia-panes">
            <div class="sia-pane">
              <div class="sia-pane-header">
                <div class="window-dots">
                  <span class="dot dot--red"></span>
                  <span class="dot dot--yellow"></span>
                  <span class="dot dot--green"></span>
                </div>
                <span class="sia-pane-lang">Python</span>
                <span class="sia-pane-file" id="py-filename">script.py</span>
              </div>
              <div id="demo-python-wrap" style="position:relative">
                <pre id="py-highlight" class="sia-editor sia-editor--highlight" aria-hidden="true"><code></code></pre>
                <textarea id="demo-python" class="sia-editor sia-editor--overlay" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"></textarea>
              </div>
              <div class="sia-stats" id="stats-python">
                <span class="sia-stat-tokens">Tokens: <b id="py-tokens">—</b></span>
                <span class="sia-stat-sep">·</span>
                <span class="sia-stat-chars">Chars: <b id="py-chars">—</b></span>
              </div>
            </div>

            <div class="sia-arrow" aria-hidden="true">→</div>

            <div class="sia-pane sia-pane--ilo">
              <div class="sia-pane-header">
                <div class="window-dots">
                  <span class="dot dot--red"></span>
                  <span class="dot dot--yellow"></span>
                  <span class="dot dot--green"></span>
                </div>
                <span class="sia-pane-lang sia-pane-lang--ilo">ilo</span>
                <span class="sia-pane-file" id="ilo-filename">script.@</span>
                <button class="sia-toggle" id="sia-toggle" title="Toggle multi-line ↔ compact">
                  <span class="sia-toggle-label" id="sia-toggle-label">compact</span>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 16V4m0 0L3 8m4-4 4 4M17 8v12m0 0 4-4m-4 4-4-4"/></svg>
                </button>
              </div>
              <div id="demo-ilo-wrap" style="position:relative">
                <pre id="demo-ilo" class="sia-editor sia-editor--ilo"><code id="ilo-code"></code></pre>
                <div class="sia-converting" id="sia-converting" style="display:none">
                  <span class="sia-converting-dot"></span>converting…
                </div>
              </div>
              <div class="sia-stats sia-stats--ilo" id="stats-ilo">
                <span class="sia-stat-tokens">Tokens: <b id="ilo-tokens">—</b></span>
                <span class="sia-stat-sep">·</span>
                <span class="sia-stat-chars">Chars: <b id="ilo-chars">—</b></span>
                <span class="sia-stat-diff" id="sia-diff"></span>
              </div>
            </div>
          </div>

          <div class="sia-controls">
            <div class="sia-presets" id="demo-presets"></div>
          </div>
          <div class="sia-seemore">
            <a class="btn-text" href="/docs/learn/examples/">
              See more examples
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>

          <div class="sia-output" id="demo-output" style="display:none">
            <div class="sia-output-label">output</div>
            <pre class="sia-output-text" id="demo-output-text"></pre>
          </div>

          <div class="sia-error" id="sia-error" style="display:none"></div>
        </div>
      </div>
    </section>

    <!-- ILO SERV demo — JSONL stdin/stdout loop -->
    <section id="ilo-serv" class="serv-section" data-animate>
      <div class="container-wide">
        <h2 class="section-title">Wire it into your agent</h2>
        <p class="section-subtitle"><code>ilo serv</code> is a long-lived JSONL loop. One JSON request per stdin line, one response per stdout line. Process-spawn overhead per call: zero.</p>

        <div class="serv-card">
          <div class="serv-prompt mono">
            <span class="dollar">$</span> ilo serv
          </div>
          <div class="serv-panes">
            <div class="serv-pane">
              <div class="serv-pane-header">
                <div class="window-dots">
                  <span class="dot dot--red"></span>
                  <span class="dot dot--yellow"></span>
                  <span class="dot dot--green"></span>
                </div>
                <span class="serv-pane-lang">stdin</span>
                <span class="serv-pane-arrow mono">→</span>
              </div>
              <pre class="serv-body">&#123;"program":"dbl x:n&gt;n;*x 2","func":"dbl","args":[21]&#125;
&#123;"program":"upr s:t&gt;t;.upr s","func":"upr","args":["hello"]&#125;
&#123;"program":"add a:n b:n&gt;n;+a b","func":"add","args":[2,"two"]&#125;</pre>
            </div>
            <div class="serv-pane serv-pane--out">
              <div class="serv-pane-header">
                <span class="serv-pane-arrow mono">←</span>
                <span class="serv-pane-lang">stdout</span>
              </div>
              <pre class="serv-body">&#123;"schemaVersion":1,"ok":42,"ms":0.4&#125;
&#123;"schemaVersion":1,"ok":"HELLO","ms":0.3&#125;
&#123;"schemaVersion":1,"error":&#123;"phase":"verify","code":"ILO-T006","msg":"expected n, got t"&#125;&#125;</pre>
            </div>
          </div>
          <div class="serv-foot">
            <span>Every line carries <code>schemaVersion</code>. Errors include phase (<code>lex</code>, <code>parse</code>, <code>verify</code>, <code>runtime</code>, <code>program</code>) and a typed code.</span>
            <a class="btn-text" href="/docs/reference/cli/#ilo-serv">
              ilo serv reference
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES — Designed for machines -->
    <section class="features" data-animate>
      <div class="container-wide">
        <h2 class="section-title">Language features</h2>
        <p class="section-subtitle">Every feature exists to reduce total token cost.</p>
        <div class="feature-grid">
          <div class="feature-card feature-card--wide">
            <div class="feature-label">Syntax</div>
            <h3>Prefix notation</h3>
            <p>Operators before operands. No parentheses. No precedence ambiguity. 22% fewer tokens, 42% fewer characters vs infix.</p>
            <div class="feature-code">
              <code><span class="syn-op">+*</span><span class="syn-p">a</span> <span class="syn-p">b</span> <span class="syn-p">c</span></code>
              <span class="feature-code-note">(a &times; b) + c</span>
            </div>
          </div>

          <div class="feature-card feature-card--wide">
            <div class="feature-label">Safety</div>
            <h3>Verified before execution</h3>
            <p>Every program is type-checked before it runs. Agents get compact error codes, not stack traces. One token, not a paragraph.</p>
            <div class="feature-code feature-code--error">
              <code>ILO-T004: expected n, got t</code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Control</div>
            <h3>Guards</h3>
            <p>Flat conditionals. No nesting. No braces.</p>
            <div class="feature-code">
              <code><span class="syn-op">&gt;=</span><span class="syn-p">sp</span> 1000 <span class="syn-s">"gold"</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Composition</div>
            <h3>Pipes</h3>
            <p>Chain functions left-to-right.</p>
            <div class="feature-code">
              <code><span class="syn-p">x</span><span class="syn-op">&gt;&gt;</span><span class="syn-fn">dbl</span><span class="syn-op">&gt;&gt;</span><span class="syn-fn">inc</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Ergonomics</div>
            <h3>Auto-unwrap !</h3>
            <p>12 tokens down to 1. Error propagation without the ceremony.</p>
            <div class="feature-code">
              <code><span class="syn-fn">inner</span><span class="syn-op">!</span> <span class="syn-p">x</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Integrations</div>
            <h3>MCP & HTTP tools</h3>
            <p>Wire external APIs as typed functions. Type-checked at load time.</p>
            <div class="feature-code">
              <code><span class="syn-op">--</span><span class="syn-p">tools</span> tools.json</code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Surface</div>
            <h3>JSON by default</h3>
            <p>Every CLI subcommand emits structured JSON. Diagnostics carry error codes, source spans, and fix metadata. No screen-scraping.</p>
            <div class="feature-code">
              <code><span class="syn-fn">ilo</span> check <span class="syn-op">--json</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Repair</div>
            <h3>Fix plans</h3>
            <p><code>ilo apply</code> consumes structured repair plans from <code>ilo check --json</code>. Agents patch ilo with ilo.</p>
            <div class="feature-code">
              <code><span class="syn-fn">ilo</span> apply <span class="syn-op">--plan</span> fix.json</code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Agent loop</div>
            <h3>ilo serv</h3>
            <p>JSONL over stdio. Each request a line in, each response a line out. The agent-shaped equivalent of an interactive REPL.</p>
            <div class="feature-code">
              <code><span class="syn-fn">ilo</span> serv program.ilo</code>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PHILOSOPHY -->
    <section class="philosophy" data-animate>
      <div class="container-wide">
        <div class="philosophy-inner">
          <p class="philosophy-quote">
            Named from <a href="https://tokipona.org/" target="_blank" rel="noopener" class="philosophy-link">Toki Pona</a> for &ldquo;tool&rdquo;&mdash;a constructed language that captures all of human expression in ~120 words. <em>ilo</em> does the same for machine programmers.
          </p>
        </div>
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section id="manifesto" class="principles">
      <div class="container-wide">
        <div class="section-head">
