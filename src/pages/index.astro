---
// Custom landing page - bypasses Starlight entirely
import BaseHead from '../components/BaseHead.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_URL, softwareApplicationSchema, websiteSchema } from '../lib/schema';
---

<html lang="en">
<head>
  <BaseHead
    title="ilo | AI Agent Language"
    description="0.33x the tokens, 0.22x the characters of Python. Type-verified before execution. A programming language with LLMs as the intended author."
  />
  <link rel="canonical" href={SITE_URL} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={SITE_URL} />
  <meta property="og:title" content="ilo | AI Agent Language" />
  <meta property="og:description" content="Token-optimised programming language for AI agents. 0.33x the tokens of Python. Type-verified before execution." />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="ilo | AI Agent Language" />
  <meta name="twitter:description" content="Token-optimised programming language for AI agents. 0.33x the tokens of Python. Type-verified before execution." />
  <JsonLd data={softwareApplicationSchema} />
  <JsonLd data={websiteSchema} />
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">ilo lang</a>
      <div class="nav-links">
        <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="nav-github">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>GitHub
        </a>
        <a href="/docs/learn/manifesto/" class="nav-manifesto">Manifesto</a>
        <a href="/docs/introduction/" class="nav-cta">Get Started</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- SEE IT IN ACTION (merged interactive demo) -->
    <section class="sia-section" data-animate>
      <div class="container">
        <h2 class="section-title">See it in action</h2>
        <p class="section-subtitle">Real Python side-by-side with its ilo equivalent. Click a preset or edit the Python yourself.</p>

        <div class="sia-card">
          <!-- Panes row -->
          <div class="sia-panes">
            <!-- Python pane -->
            <div class="sia-pane">
              <div class="sia-pane-header">
                <div class="window-dots">
                  <span class="dot dot--red"></span>
                  <span class="dot dot--yellow"></span>
                  <span class="dot dot--green"></span>
                </div>
                <span class="sia-pane-lang">Python</span>
                <span class="sia-pane-file" id="py-filename">script.py</span>
              </div>
              <textarea id="demo-python" class="sia-editor" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"></textarea>
              <div class="sia-stats" id="stats-python">
                <span class="sia-stat-tokens">Tokens: <b id="py-tokens">—</b></span>
                <span class="sia-stat-sep">·</span>
                <span class="sia-stat-chars">Chars: <b id="py-chars">—</b></span>
              </div>
            </div>

            <!-- Arrow -->
            <div class="sia-arrow" aria-hidden="true">→</div>

            <!-- ilo pane -->
            <div class="sia-pane sia-pane--ilo">
              <div class="sia-pane-header">
                <div class="window-dots">
                  <span class="dot dot--red"></span>
                  <span class="dot dot--yellow"></span>
                  <span class="dot dot--green"></span>
                </div>
                <span class="sia-pane-lang sia-pane-lang--ilo">ilo</span>
                <span class="sia-pane-file" id="ilo-filename">script.ilo</span>
                <button class="sia-toggle" id="sia-toggle" title="Toggle multi-line ↔ inline">
                  <span class="sia-toggle-label" id="sia-toggle-label">multi-line</span>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 16V4m0 0L3 8m4-4 4 4M17 8v12m0 0 4-4m-4 4-4-4"/></svg>
                </button>
              </div>
              <div id="demo-ilo-wrap" style="position:relative">
                <textarea id="demo-ilo" class="sia-editor sia-editor--ilo" spellcheck="false" readonly></textarea>
                <div class="sia-converting" id="sia-converting" style="display:none">
                  <span class="sia-converting-dot"></span>converting…
                </div>
              </div>
              <div class="sia-stats sia-stats--ilo" id="stats-ilo">
                <span class="sia-stat-tokens">Tokens: <b id="ilo-tokens">—</b></span>
                <span class="sia-stat-sep">·</span>
                <span class="sia-stat-chars">Chars: <b id="ilo-chars">—</b></span>
                <span class="sia-stat-diff" id="sia-diff"></span>
              </div>
            </div>
          </div>

          <!-- Controls: presets + convert -->
          <div class="sia-controls">
            <div class="sia-presets" id="demo-presets">
              <!-- chips injected by JS -->
            </div>
            <button class="sia-convert-btn" id="sia-convert-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M19 7l-7 7-7-7"/></svg>
              Convert
            </button>
          </div>

          <!-- Output -->
          <div class="sia-output" id="demo-output" style="display:none">
            <div class="sia-output-label">output</div>
            <pre class="sia-output-text" id="demo-output-text"></pre>
          </div>

          <!-- Error -->
          <div class="sia-error" id="sia-error" style="display:none"></div>
        </div>
      </div>
    </section>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
      <div class="container hero-content">
        <div class="hero-badge">programming language for AI agents</div>
        <h1 class="hero-title">ilo</h1>
        <p class="hero-tagline">
          A programming language with LLMs as the intended author.<br />
          <span class="hero-tagline-accent">0.33&times; the tokens. 0.22&times; the characters. Type-verified before execution.</span>
        </p>
        <div class="install-tabs">
          <div class="tab-buttons">
            <button class="tab-btn active" data-tab="mac">macOS / Linux</button>
            <button class="tab-btn" data-tab="windows">Windows</button>
            <button class="tab-btn" data-tab="claude">Claude Code</button>
          </div>
          <div class="hero-terminal" id="install-cmd">
            <span class="terminal-prompt">$</span>
            <span class="terminal-text" data-cmd="mac">curl -fsSL https://raw.githubusercontent.com/ilo-lang/ilo/main/install.sh | sh</span>
            <span class="terminal-text" data-cmd="windows" style="display:none">irm https://raw.githubusercontent.com/ilo-lang/ilo/main/install.ps1 | iex</span>
            <span class="terminal-text" data-cmd="claude" style="display:none">/plugin marketplace add ilo-lang/ilo && /plugin install ilo-lang/ilo</span>
            <button class="terminal-copy" id="copy-btn" aria-label="Copy install command">
              <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/docs/introduction/" class="btn btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="btn btn-outline">
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats" data-animate>
      <div class="container stats-grid">
        <div class="stat">
          <div class="stat-number">67%</div>
          <div class="stat-label">fewer tokens</div>
          <div class="stat-context">vs Python</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <div class="stat-number">78%</div>
          <div class="stat-label">fewer characters</div>
          <div class="stat-context">vs Python</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <div class="stat-number">&check;</div>
          <div class="stat-label">type-verified</div>
          <div class="stat-context">before execution</div>
        </div>
      </div>
    </section>

    <!-- CODE COMPARISON -->
    <section class="comparison" data-animate>
      <div class="container">
        <h2 class="section-title">Same semantics. Fewer tokens.</h2>
        <p class="section-subtitle">A real function. Same logic. See the difference.</p>
        <div class="compare-grid">
          <div class="code-window code-window--muted">
            <div class="code-header">
              <div class="window-dots">
                <span class="dot dot--red"></span>
                <span class="dot dot--yellow"></span>
                <span class="dot dot--green"></span>
              </div>
              <span class="code-filename">total.py</span>
              <span class="code-badge">~30 tokens &middot; 120 chars</span>
            </div>
            <pre class="code-body"><code><span class="syn-kw">def</span> <span class="syn-fn">total</span>(<span class="syn-p">p</span>: <span class="syn-t">float</span>, <span class="syn-p">q</span>: <span class="syn-t">int</span>, <span class="syn-p">r</span>: <span class="syn-t">float</span>) -> <span class="syn-t">float</span>:
    <span class="syn-p">s</span> = <span class="syn-p">p</span> * <span class="syn-p">q</span>
    <span class="syn-p">t</span> = <span class="syn-p">s</span> * <span class="syn-p">r</span>
    <span class="syn-kw">return</span> <span class="syn-p">s</span> + <span class="syn-p">t</span></code></pre>
          </div>
          <div class="code-window code-window--highlight">
            <div class="code-header">
              <div class="window-dots">
                <span class="dot dot--red"></span>
                <span class="dot dot--yellow"></span>
                <span class="dot dot--green"></span>
              </div>
              <span class="code-filename">total.ilo</span>
              <span class="code-badge code-badge--accent">~10 tokens &middot; 38 chars</span>
            </div>
            <pre class="code-body"><code><span class="syn-fn">tot</span> <span class="syn-p">p</span><span class="syn-t">:n</span> <span class="syn-p">q</span><span class="syn-t">:n</span> <span class="syn-p">r</span><span class="syn-t">:n</span><span class="syn-op">&gt;</span><span class="syn-t">n</span>;<span class="syn-p">s</span>=<span class="syn-op">*</span><span class="syn-p">p</span> <span class="syn-p">q</span>;<span class="syn-p">t</span>=<span class="syn-op">*</span><span class="syn-p">s</span> <span class="syn-p">r</span>;<span class="syn-op">+</span><span class="syn-p">s</span> <span class="syn-p">t</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features" data-animate>
      <div class="container">
        <h2 class="section-title">Designed for machines</h2>
        <p class="section-subtitle">Every feature exists to reduce total token cost.</p>
        <div class="feature-grid">

          <div class="feature-card feature-card--wide">
            <div class="feature-label">Syntax</div>
            <h3>Prefix Notation</h3>
            <p>Operators before operands. No parentheses. No precedence ambiguity. 22% fewer tokens, 42% fewer characters vs infix.</p>
            <div class="feature-code">
              <code><span class="syn-op">+*</span><span class="syn-p">a</span> <span class="syn-p">b</span> <span class="syn-p">c</span></code>
              <span class="feature-code-note">(a &times; b) + c</span>
            </div>
          </div>

          <div class="feature-card feature-card--wide">
            <div class="feature-label">Safety</div>
            <h3>Verified Before Execution</h3>
            <p>Every program is type-checked before it runs. Agents get compact error codes, not stack traces. One token, not a paragraph.</p>
            <div class="feature-code feature-code--error">
              <code>ILO-T004: expected n, got t</code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Control</div>
            <h3>Guards</h3>
            <p>Flat conditionals. No nesting. No braces.</p>
            <div class="feature-code">
              <code><span class="syn-op">&gt;=</span><span class="syn-p">sp</span> 1000 <span class="syn-s">"gold"</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Composition</div>
            <h3>Pipes</h3>
            <p>Chain functions left-to-right.</p>
            <div class="feature-code">
              <code><span class="syn-p">x</span><span class="syn-op">&gt;&gt;</span><span class="syn-fn">dbl</span><span class="syn-op">&gt;&gt;</span><span class="syn-fn">inc</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Ergonomics</div>
            <h3>Auto-unwrap !</h3>
            <p>12 tokens down to 1. Error propagation without the ceremony.</p>
            <div class="feature-code">
              <code><span class="syn-fn">inner</span><span class="syn-op">!</span> <span class="syn-p">x</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Integrations</div>
            <h3>MCP & HTTP Tools</h3>
            <p>Wire external APIs as typed functions. Type-checked at load time.</p>
            <div class="feature-code">
              <code><span class="syn-op">--</span><span class="syn-p">tools</span> tools.json</code>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- examples section removed — merged into sia-section above -->

    <!-- PHILOSOPHY -->
    <section class="philosophy" data-animate>
      <div class="container">
        <div class="philosophy-inner">
          <p class="philosophy-quote">
            Named from <a href="https://tokipona.org/" target="_blank" rel="noopener" class="philosophy-link">Toki Pona</a> for &ldquo;tool&rdquo;&mdash;a constructed language that captures all of human expression in ~120 words. <em>ilo</em> does the same for machine programmers.
          </p>
        </div>
      </div>
    </section>

    <!-- SIX PRINCIPLES -->
    <section class="manifesto-section" data-animate>
      <div class="container">
        <h2 class="section-title">What ilo Optimizes For</h2>
        <p class="section-subtitle">Six principles, all measured against one metric: total tokens from intent to working code.</p>
        <div class="manifesto-grid">
          <a href="/docs/learn/manifesto/#1-token-conservative" class="manifesto-card">
            <div class="manifesto-num">01</div>
            <h3>Token-Conservative</h3>
            <p>The north star. Every choice evaluated against total token cost across the full loop&mdash;not just short syntax, but retries, errors, and context loading.</p>
          </a>
          <a href="/docs/learn/manifesto/#2-constrained" class="manifesto-card">
            <div class="manifesto-num">02</div>
            <h3>Constrained</h3>
            <p>Small vocabulary. Closed world. Few ways to do things. Fewer valid next-tokens means fewer wrong choices means fewer retries.</p>
          </a>
          <a href="/docs/learn/manifesto/#3-self-contained" class="manifesto-card">
            <div class="manifesto-num">03</div>
            <h3>Self-Contained</h3>
            <p>Each unit carries its own context: deps, types, rules. The agent never needs to hunt for definitions elsewhere.</p>
          </a>
          <a href="/docs/learn/manifesto/#4-language-agnostic" class="manifesto-card">
            <div class="manifesto-num">04</div>
            <h3>Language-Agnostic</h3>
            <p>Minimise dependency on English or any natural language. Sigils and short names over prose keywords.</p>
          </a>
          <a href="/docs/learn/manifesto/#5-graph-reducible" class="manifesto-card">
            <div class="manifesto-num">05</div>
            <h3>Graph-Reducible</h3>
            <p>When analysing code, load only the relevant subgraph. As programs grow, the savings compound.</p>
          </a>
          <a href="/docs/learn/manifesto/#6-structured-compiler-to-agent-surface" class="manifesto-card">
            <div class="manifesto-num">06</div>
            <h3>Structured Compiler-to-Agent Surface</h3>
            <p>Every path from the compiler to an agent is machine-readable by default. JSON out, zero screen-scraping.</p>
          </a>
        </div>
        <div class="manifesto-cta">
          <a href="/docs/learn/manifesto/" class="btn btn-outline">Read the full manifesto &rarr;</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="final-cta" data-animate>
      <div class="container">
        <p class="cta-statement">Make your agents more efficient.</p>
        <div class="hero-actions">
          <a href="/docs/introduction/" class="btn btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="btn btn-outline">
            View on GitHub
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-left">
        <span class="footer-logo">ilo</span>
        <a href="https://github.com/ilo-lang/ilo/blob/main/LICENSE" target="_blank" rel="noopener" class="footer-copy">MIT License</a>
        <span class="footer-byline"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px"><rect width="18" height="10" x="3" y="11" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/></svg>Built for robots</span>
      </div>
      <div class="footer-links">
        <a href="/docs/introduction/">Docs</a>
        <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.npmjs.com/package/ilo-lang" target="_blank" rel="noopener">npm</a>
        <a href="https://crates.io/crates/ilo" target="_blank" rel="noopener">crates.io</a>
        <a href="/contact/">Contact</a>
        <a href="https://github.com/ilo-lang/ilo/blob/main/PRIVACY.md" target="_blank" rel="noopener">Privacy</a>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  /* ===== RESET ===== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* ===== VARIABLES ===== */
  :root {
    --bg: #08080c;
    --bg-raised: #0e0e14;
    --bg-card: #111118;
    --bg-card-hover: #16161f;
    --border: rgba(255, 255, 255, 0.06);
    --border-hover: rgba(245, 158, 11, 0.25);
    --text: #e4e4e8;
    --text-muted: #9a9ab0;
    --text-dim: #6e6e88;
    --accent: #f59e0b;
    --accent-bright: #fbbf24;
    --accent-dim: rgba(245, 158, 11, 0.08);
    --font-display: 'Bricolage Grotesque', system-ui, sans-serif;
    --font-body: 'Bricolage Grotesque', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --font-serif: 'Instrument Serif', Georgia, serif;
    --container: 1100px;
  }

  /* ===== BASE ===== */
  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-variant-ligatures: none;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* ===== NAV ===== */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(8, 8, 12, 0.8);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--accent);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-links a {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-github {
    display: flex;
    align-items: center;
    gap: 0.3em;
  }

  .nav-manifesto {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-manifesto:hover {
    color: var(--text);
  }

  .nav-cta {
    background: var(--accent) !important;
    color: #000 !important;
    padding: 6px 16px;
    border-radius: 6px;
    font-weight: 600 !important;
    font-size: 1rem !important;
    transition: filter 0.2s;
  }

  .nav-cta:hover {
    filter: brightness(1.15);
    color: #000 !important;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 60px;
  }

  .hero-glow {
    position: absolute;
    top: 15%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(245, 158, 11, 0.07) 0%, rgba(245, 158, 11, 0.02) 40%, transparent 70%);
    pointer-events: none;
    animation: glowPulse 6s ease-in-out infinite;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 20%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(7rem, 18vw, 14rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    color: var(--text);
    animation: heroReveal 1s ease forwards;
  }

  .hero-tagline {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 400;
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  .hero-tagline-accent {
    color: var(--text);
    font-weight: 500;
  }

  .install-tabs {
    animation: fadeInUp 0.8s ease 0.35s forwards;
    opacity: 0;
  }

  .tab-buttons {
    display: flex;
    justify-content: center;
    gap: 2px;
    margin-bottom: 0;
  }

  .tab-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-bottom: none;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 8px 16px;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    border-radius: 6px 6px 0 0;
  }

  .tab-btn:hover {
    color: var(--text-muted);
  }

  .tab-btn.active {
    background: var(--bg-raised);
    color: var(--accent);
    border-color: var(--border);
  }

  .hero-terminal {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    cursor: pointer;
    transition: border-color 0.3s, box-shadow 0.3s;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-terminal:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.06);
  }

  .terminal-prompt {
    color: var(--text-dim);
    user-select: none;
  }

  .terminal-text {
    color: var(--accent-bright);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .terminal-copy {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .terminal-copy:hover {
    color: var(--accent);
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s ease 0.5s forwards;
    opacity: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
  }

  .btn-primary:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
  }

  .btn-outline {
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .btn-outline:hover {
    border-color: var(--border-hover);
    color: var(--accent);
  }

  /* ===== STATS ===== */
  .stats {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
    min-width: 160px;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4rem);
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    margin-top: 0.5rem;
  }

  .stat-context {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
    font-family: var(--font-mono);
  }

  .stat-divider {
    width: 1px;
    height: 48px;
    background: var(--border);
  }

  /* ===== SECTIONS (shared) ===== */
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  /* ===== CODE COMPARISON ===== */
  .comparison {
    padding: 6rem 0;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .code-window {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-raised);
  }

  .code-window--muted {
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .code-window--muted:hover {
    opacity: 0.9;
  }

  .code-window--highlight {
    border-color: rgba(245, 158, 11, 0.2);
    box-shadow: 0 0 40px rgba(245, 158, 11, 0.04);
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.015);
  }

  .window-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.5;
  }

  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #febc2e; }
  .dot--green { background: #28c840; }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
  }

  .code-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.04);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .code-badge--accent {
    color: var(--accent);
    background: var(--accent-dim);
  }

  .code-body {
    padding: 20px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    overflow-x: auto;
    background: transparent;
    color: var(--text);
  }

  .code-body code {
    font-family: inherit;
  }

  /* ===== SYNTAX COLORS ===== */
  .syn-kw { color: #c792ea; }
  .syn-fn { color: #82aaff; }
  .syn-p { color: #d6d6e0; }
  .syn-t { color: #89ddff; }
  .syn-s { color: #c3e88d; }
  .syn-op { color: #f59e0b; }
  .syn-cm { color: #546e7a; }

  /* ===== FEATURES ===== */
  .features {
    padding: 6rem 0;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.3s, transform 0.2s, box-shadow 0.3s;
  }

  .feature-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .feature-card--wide {
    grid-column: span 1;
  }

  .feature-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .feature-code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: rgba(0, 0, 0, 0.25);
    padding: 10px 14px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 12px;
    overflow-x: auto;
  }

  .feature-code code {
    font-family: inherit;
    white-space: nowrap;
  }

  .feature-code-note {
    color: var(--text-dim);
    font-size: 0.75rem;
    white-space: nowrap;
  }

  .feature-code--error code {
    color: #f87171;
  }

  .syn-dim { color: var(--text-dim); }
  .syn-result { color: var(--accent); font-weight: 500; }

  /* ===== SEE IT IN ACTION (merged demo) ===== */
  .sia-section {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
  }

  .sia-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    max-width: 1000px;
    margin: 0 auto;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .sia-card:hover {
    border-color: rgba(245, 158, 11, 0.12);
    box-shadow: 0 4px 40px rgba(0,0,0,0.3);
  }

  /* Panes layout */
  .sia-panes {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 14px;
    align-items: start;
    margin-bottom: 18px;
  }

  .sia-pane {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .sia-pane-header {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.015);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    padding: 9px 14px;
  }

  .sia-pane-lang {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex: 1;
  }

  .sia-pane-lang--ilo {
    color: var(--accent);
  }

  .sia-pane-file {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .sia-toggle {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    color: var(--text-dim);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 8px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .sia-toggle:hover {
    color: var(--accent);
    border-color: rgba(245,158,11,0.3);
  }

  .sia-toggle-label {
    pointer-events: none;
  }

  .sia-editor {
    width: 100%;
    min-height: 155px;
    background: rgba(0,0,0,0.28);
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--text);
    resize: none;
    outline: none;
    white-space: pre;
    overflow-x: auto;
    overflow-y: hidden;
    transition: border-color 0.2s, opacity 0.15s;
    field-sizing: content;
  }

  .sia-editor:focus {
    border-color: rgba(245,158,11,0.2);
  }

  .sia-editor--ilo {
    border-color: rgba(245,158,11,0.15);
    color: var(--accent-bright);
    cursor: default;
  }

  .sia-editor.is-fading {
    opacity: 0;
  }

  .sia-converting {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    border-radius: 0 0 8px 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    gap: 8px;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .sia-converting-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: dotPulse 1s ease-in-out infinite;
  }

  /* Stats row */
  .sia-stats {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    flex-wrap: wrap;
  }

  .sia-stats--ilo {
    color: var(--text-muted);
  }

  .sia-stat-sep {
    opacity: 0.4;
  }

  .sia-stat-diff {
    font-weight: 700;
    color: #4ade80;
    transition: transform 0.2s;
  }

  .sia-stat-diff.bounce {
    animation: diffBounce 0.4s ease;
  }

  @keyframes diffBounce {
    0% { transform: scale(1); }
    40% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  /* Arrow */
  .sia-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 40px;
    font-size: 1.5rem;
    color: var(--accent);
    opacity: 0.45;
    user-select: none;
  }

  /* Controls */
  .sia-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .sia-presets {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    flex: 1;
  }

  .sia-preset-chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    padding: 6px 13px;
    border-radius: 100px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.15s;
  }

  .sia-preset-chip:hover {
    color: var(--accent);
    border-color: rgba(245,158,11,0.3);
    background: var(--accent-dim);
  }

  .sia-preset-chip.active {
    color: var(--accent);
    border-color: rgba(245,158,11,0.4);
    background: var(--accent-dim);
  }

  .sia-convert-btn {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: #000;
    background: var(--accent);
    border: none;
    padding: 8px 18px;
    border-radius: 6px;
    cursor: pointer;
    transition: filter 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sia-convert-btn:hover {
    filter: brightness(1.1);
  }

  .sia-convert-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    filter: none;
  }

  /* Output */
  .sia-output {
    border-top: 1px solid var(--border);
    padding-top: 14px;
    margin-top: 4px;
  }

  .sia-output-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .sia-output-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .sia-error {
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #f87171;
    background: rgba(248,113,113,0.06);
    border: 1px solid rgba(248,113,113,0.15);
    border-radius: 6px;
    padding: 10px 14px;
  }

  @media (max-width: 700px) {
    .sia-panes {
      grid-template-columns: 1fr;
    }
    .sia-arrow {
      display: none;
    }
    .sia-card {
      padding: 18px;
    }
  }

  /* ===== SIX PRINCIPLES ===== */
  .manifesto-section {
    padding: 6rem 0;
  }

  .manifesto-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .manifesto-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.3s, transform 0.2s, box-shadow 0.3s;
    text-decoration: none;
    display: block;
  }

  .manifesto-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .manifesto-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  .manifesto-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .manifesto-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .manifesto-cta {
    text-align: center;
  }

  @media (max-width: 900px) {
    .manifesto-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .manifesto-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== PHILOSOPHY ===== */
  .philosophy {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .philosophy-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .philosophy-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .philosophy-quote em {
    color: var(--text);
    font-style: italic;
  }

  .philosophy-link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255,255,255,0.15);
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .philosophy-link:hover {
    color: var(--text);
    text-decoration-color: var(--accent);
  }

  .principles {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .principle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 100px;
    transition: border-color 0.2s, color 0.2s;
  }

  .principle:hover {
    border-color: var(--border-hover);
    color: var(--accent);
  }

  /* ===== FINAL CTA ===== */
  .final-cta {
    padding: 6rem 0;
    text-align: center;
  }

  .cta-statement {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    color: var(--text);
  }

  /* ===== FOOTER ===== */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
