  .term-cta:hover { color: var(--ilo-amber-high); }
  .term-cta.is-copied { color: var(--ilo-green); }

  /* OS / agent chips */
  .install-os-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .os-chip, .agent-chip {
    font-family: var(--ilo-font-mono); font-size: 11.5px;
